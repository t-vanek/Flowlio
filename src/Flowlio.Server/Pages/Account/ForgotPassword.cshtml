@page
@model Flowlio.Server.Pages.Account.ForgotPasswordModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Obnova hesla – Flowlio</title>
    <link rel="stylesheet" href="~/css/account.css" />
</head>
<body style="align-items:center;">
    <form class="card narrow" method="post">
        <div class="logo">₣ Flowlio</div>
        <h1>Obnova hesla</h1>

        @if (Model.Sent)
        {
            <div class="info">Pokud účet s tímto e-mailem existuje, poslali jsme na něj odkaz pro obnovu hesla.</div>
        }
        else
        {
            <label for="Email">E-mail</label>
            <input id="Email" name="Email" type="email" value="@Model.Email" autofocus />
            <button type="submit" class="block">Poslat odkaz</button>
        }

        <div class="switch"><a href="/Account/Login">Zpět na přihlášení</a></div>
    </form>
</body>
</html>
