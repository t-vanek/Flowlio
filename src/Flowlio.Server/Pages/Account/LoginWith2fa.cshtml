@page
@model Flowlio.Server.Pages.Account.LoginWith2faModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dvoufaktorové ověření – Flowlio</title>
    <link rel="stylesheet" href="~/css/account.css" />
</head>
<body style="align-items:center;">
    <form class="card narrow" method="post">
        <div class="logo">₣ Flowlio</div>
        <h1>Dvoufaktorové ověření</h1>
        <p class="muted">Zadejte 6-místný kód z autentizační aplikace. Pokud k ní nemáte přístup, použijte záchranný kód.</p>

        @if (!string.IsNullOrEmpty(Model.Error))
        {
            <div class="err">@Model.Error</div>
        }

        <label for="Code">Kód</label>
        <input id="Code" name="Code" type="text" inputmode="numeric" pattern="[-0-9 ]*"
               autocomplete="one-time-code" autofocus />

        <label class="check"><input type="checkbox" name="IsRecoveryCode" value="true" /> Použít záchranný kód</label>
        <label class="check"><input type="checkbox" name="RememberMachine" value="true" /> Zapamatovat toto zařízení</label>

        <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
        <button type="submit" class="block">Ověřit</button>
    </form>
</body>
</html>
