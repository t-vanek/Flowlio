@page "{returnUrl?}"
@model Flowlio.Server.Pages.Account.TwoFactorModel
@{
    Layout = null;
    // Only honour a local returnUrl so a crafted ?returnUrl=https://evil link can't turn the
    // continue/skip links into an open redirect.
    var safeReturn = !string.IsNullOrWhiteSpace(Model.ReturnUrl) && Url.IsLocalUrl(Model.ReturnUrl)
        ? Model.ReturnUrl
        : null;
}
<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Zabezpečení – Flowlio</title>
    <link rel="stylesheet" href="~/css/account.css" />
</head>
<body>
    <div class="card">
        <div class="logo">₣ Flowlio</div>
        <h1>Zabezpečení účtu</h1>
        <p class="muted">Dvoufaktorové ověření přidává druhou vrstvu – kromě hesla budete potřebovat kód z autentizační aplikace.</p>

        @if (Model.Require2faBy is { } deadline && !Model.Is2faEnabled)
        {
            var expired = deadline < DateTimeOffset.UtcNow;
            <div class="force-2fa-banner @(expired ? "expired" : "")">
                @if (expired)
                {
                    <strong>Lhůta pro zapnutí 2FA vypršela @deadline.LocalDateTime.ToString("d.M.yyyy HH:mm").</strong>
                    <span> Bez 2FA se nemůžete přihlásit do aplikace. Zapněte ji teď nebo kontaktujte administrátora.</span>
                }
                else
                {
                    <strong>Administrátor vyžaduje zapnutí 2FA do @deadline.LocalDateTime.ToString("d.M.yyyy HH:mm").</strong>
                    <span> Bez něj se po této lhůtě nebudete moci přihlásit.</span>
                }
            </div>
        }

        @if (Model.Status is not null)
        {
            <div class="ok">@Model.Status</div>
        }
        @if (Model.Error is not null)
        {
            <div class="err">@Model.Error</div>
        }

        @if (Model.RecoveryCodes is { Length: > 0 })
        {
            <h2>Záchranné kódy</h2>
            <p class="muted">Každý kód lze použít jednou, pokud ztratíte přístup k aplikaci. Uložte si je nyní – po opuštění stránky už je tady neuvidíte.</p>
            <div class="codes">
                @foreach (var code in Model.RecoveryCodes)
                {
                    <div>@code</div>
                }
            </div>
            <div class="btn-row">
                <form method="post" asp-page-handler="DownloadRecovery" asp-route-returnUrl="@safeReturn">
                    <button type="submit" class="ghost">⬇ Stáhnout jako .txt</button>
                </form>
                <button type="button" class="ghost" onclick="copyCodes(this)">📋 Kopírovat</button>
            </div>
        }

        @if (Model.Is2faEnabled)
        {
            <h2>Stav: 2FA je zapnutá ✓</h2>
            <p class="muted">Účet je chráněn. Můžete si vygenerovat nové záchranné kódy (předchozí se zneplatní) nebo 2FA vypnout.</p>
            @if (Model.RecoveryCodes is null or { Length: 0 })
            {
                @if (Model.RecoveryCodesLeft <= 3)
                {
                    <div class="force-2fa-banner expired">
                        Zbývá @Model.RecoveryCodesLeft záchranných kódů. Vygenerujte si prosím nové, ať se nezamknete.
                    </div>
                }
                else
                {
                    <p class="muted">Zbývá @Model.RecoveryCodesLeft záchranných kódů.</p>
                }
            }
            <div class="btn-row">
                <form method="post" asp-page-handler="Regenerate" asp-route-returnUrl="@safeReturn">
                    <button type="submit">Vygenerovat nové záchranné kódy</button>
                </form>
                <form method="post" asp-page-handler="Disable" asp-route-returnUrl="@safeReturn" onsubmit="return confirmDisable();">
                    <button type="submit" class="danger">Vypnout 2FA</button>
                </form>
            </div>

            <div class="switch"><a href="@(safeReturn ?? "/")">Pokračovat do aplikace</a></div>
        }
        else
        {
            <h2>Krok 1 – Nascanujte QR kód</h2>
            <p class="muted">Otevřete autentizační aplikaci (Google Authenticator, Microsoft Authenticator, Authy…) a přidejte účet naskenováním:</p>

            <div class="qr-block">
                @if (Model.AuthenticatorQrDataUri is not null)
                {
                    <img src="@Model.AuthenticatorQrDataUri" alt="QR kód pro authenticator" />
                }
                <div class="qr-text">
                    <p class="muted">Nemůžete naskenovat? Zadejte klíč ručně:</p>
                    <div class="copy-row">
                        <span class="code" id="shared-key">@Model.SharedKey</span>
                        <button type="button" class="copy-btn" onclick="copyText('shared-key', this)">Kopírovat</button>
                    </div>
                </div>
            </div>

            <h2>Krok 2 – Potvrďte 6-místným kódem</h2>
            <form method="post" asp-page-handler="Enable" asp-route-returnUrl="@safeReturn">
                <label for="VerificationCode">Kód z aplikace</label>
                <input id="VerificationCode" name="VerificationCode" type="text" inputmode="numeric"
                       pattern="[0-9 -]*" autocomplete="one-time-code" autofocus />
                <button type="submit" class="block">Zapnout 2FA</button>
            </form>

            <div class="switch"><a href="@(safeReturn ?? "/")">Pokračovat bez zapnutí</a></div>
        }
    </div>

    <script>
        function copyText(elementId, btn) {
            const el = document.getElementById(elementId);
            if (!el) return;
            const text = (el.innerText || el.textContent || '').trim();
            navigator.clipboard.writeText(text).then(() => flashButton(btn, 'Zkopírováno ✓'));
        }
        function copyCodes(btn) {
            const text = Array.from(document.querySelectorAll('.codes > div'))
                .map(d => (d.innerText || d.textContent || '').trim())
                .join('\n');
            navigator.clipboard.writeText(text).then(() => flashButton(btn, 'Zkopírováno ✓'));
        }
        function flashButton(btn, label) {
            if (!btn) return;
            const original = btn.innerText;
            btn.innerText = label;
            setTimeout(() => { btn.innerText = original; }, 1600);
        }
        function confirmDisable() {
            return confirm('Opravdu vypnout dvoufaktorové ověření? Účet bude chráněn jen heslem.');
        }
    </script>
</body>
</html>
