@page
@model Flowlio.Server.Pages.Account.ChangePasswordModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Změna hesla – Flowlio</title>
    <link rel="stylesheet" href="~/css/account.css" />
</head>
<body style="align-items:center;">
    <form class="card narrow" method="post">
        <div class="logo">₣ Flowlio</div>
        <h1>Změna hesla</h1>

        @if (Model.Required)
        {
            <div class="info">Administrátor vyžaduje nastavení nového hesla, než budete pokračovat.</div>
        }
        @if (!string.IsNullOrEmpty(Model.Error))
        {
            <div class="err">@Model.Error</div>
        }

        <label for="CurrentPassword">Současné heslo</label>
        <input id="CurrentPassword" name="CurrentPassword" type="password" autofocus />

        <label for="NewPassword">Nové heslo</label>
        <input id="NewPassword" name="NewPassword" type="password" />

        <label for="ConfirmPassword">Nové heslo znovu</label>
        <input id="ConfirmPassword" name="ConfirmPassword" type="password" />

        <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
        <button type="submit" class="block">Uložit nové heslo</button>
    </form>
</body>
</html>
