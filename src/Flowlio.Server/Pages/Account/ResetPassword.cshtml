@page
@model Flowlio.Server.Pages.Account.ResetPasswordModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nové heslo – Flowlio</title>
    <style>
        body { font-family: 'Segoe UI', Helvetica, Arial, sans-serif; margin: 0; min-height: 100vh;
               display: flex; align-items: center; justify-content: center;
               background: linear-gradient(135deg,#1e3a8a,#2563eb); }
        .card { background:#fff; padding:32px; border-radius:14px; width:100%; max-width:380px;
                box-shadow:0 20px 50px rgba(0,0,0,.25); }
        .logo { font-size:22px; font-weight:800; color:#2563eb; margin-bottom:18px; }
        h1 { font-size:24px; margin:0 0 18px; }
        label { display:block; font-size:13px; color:#475569; margin:12px 0 4px; }
        input { width:100%; box-sizing:border-box; padding:10px 12px; border:1px solid #cbd5e1;
                border-radius:8px; font-size:15px; }
        button { width:100%; margin-top:20px; padding:11px; border:0; border-radius:8px;
                 background:#2563eb; color:#fff; font-size:15px; font-weight:600; cursor:pointer; }
        .err { background:#fee2e2; color:#b91c1c; padding:10px; border-radius:8px; margin-top:14px; font-size:14px; }
        .info { background:#dcfce7; color:#166534; padding:10px; border-radius:8px; margin-top:14px; font-size:14px; }
        .switch { text-align:center; margin-top:18px; font-size:14px; color:#64748b; }
    </style>
</head>
<body>
    <form class="card" method="post">
        <div class="logo">₣ Flowlio</div>
        <h1>Nové heslo</h1>

        @if (Model.Done)
        {
            <div class="info">Heslo bylo změněno. Nyní se můžete přihlásit.</div>
            <div class="switch"><a href="/Account/Login">Přejít na přihlášení</a></div>
        }
        else
        {
            @if (!string.IsNullOrEmpty(Model.Error))
            {
                <div class="err">@Model.Error</div>
            }

            <input type="hidden" name="Email" value="@Model.Email" />
            <input type="hidden" name="Token" value="@Model.Token" />

            <label for="Password">Nové heslo</label>
            <input id="Password" name="Password" type="password" autofocus />

            <label for="ConfirmPassword">Nové heslo znovu</label>
            <input id="ConfirmPassword" name="ConfirmPassword" type="password" />

            <button type="submit">Nastavit heslo</button>
            <div class="switch"><a href="/Account/Login">Zpět na přihlášení</a></div>
        }
    </form>
</body>
</html>
