@page
@model Flowlio.Server.Pages.Account.RegisterModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registrace – Flowlio</title>
    <link rel="stylesheet" href="~/css/account.css" />
</head>
<body style="align-items:center;">
@if (Model.AwaitingConfirmation)
{
    <div class="card narrow">
        <div class="logo">₣ Flowlio</div>
        <h1>Zkontrolujte e-mail</h1>
        <p class="muted">Poslali jsme potvrzovací odkaz na <strong>@Model.Email</strong>. Po jeho otevření se budete moci přihlásit.</p>
        @if (Model.DevConfirmLink is not null)
        {
            <div class="info" style="word-break:break-all;">[DEV] <a href="@Model.DevConfirmLink">Potvrdit e-mail</a></div>
        }
        <div class="switch"><a href="/Account/Login">Zpět na přihlášení</a></div>
    </div>
}
else
{
    <form class="card narrow" method="post">
        <div class="logo">₣ Flowlio</div>
        <h1>Vytvořit účet</h1>

        @if (!string.IsNullOrEmpty(Model.InvitedToFamily))
        {
            <div class="info">Byli jste pozváni do rodiny ve Flowlio. Dokončete registraci a získáte přístup.</div>
        }

        @if (!string.IsNullOrEmpty(Model.Error))
        {
            <div class="err">@Model.Error</div>
        }

        <label for="DisplayName">Jméno</label>
        <input id="DisplayName" name="DisplayName" value="@Model.DisplayName" autofocus />

        <label for="Email">E-mail</label>
        <input id="Email" name="Email" type="email" value="@Model.Email" />

        <label for="Password">Heslo (min. 8 znaků)</label>
        <input id="Password" name="Password" type="password" />

        <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
        <input type="hidden" name="Invite" value="@Model.Invite" />
        <button type="submit" class="block">Zaregistrovat se</button>

        <div class="switch">Už máte účet? <a href="/Account/Login?returnUrl=@Uri.EscapeDataString(Model.ReturnUrl ?? "/")">Přihlaste se</a></div>
    </form>
}
</body>
</html>
