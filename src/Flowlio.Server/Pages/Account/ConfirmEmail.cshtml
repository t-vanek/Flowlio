@page
@model Flowlio.Server.Pages.Account.ConfirmEmailModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Potvrzení e-mailu – Flowlio</title>
    <link rel="stylesheet" href="~/css/account.css" />
</head>
<body style="align-items:center;">
    <div class="card narrow" style="text-align:center;">
        <div class="logo">₣ Flowlio</div>
        @if (Model.Confirmed)
        {
            <h1>E-mail potvrzen ✓</h1>
            <p>Děkujeme, vaše e-mailová adresa byla ověřena. Teď se můžete přihlásit.</p>
            <a class="btn" href="@Model.LoginUrl">Přihlásit se</a>
        }
        else
        {
            <h1>Odkaz není platný</h1>
            <p>Potvrzovací odkaz je neplatný nebo vypršel. Zkuste registraci znovu nebo si nechte poslat nový odkaz při přihlášení.</p>
            <div class="switch"><a href="/Account/Login">Zpět na přihlášení</a></div>
        }
    </div>
</body>
</html>
