@page
@model Flowlio.Server.Pages.Account.ConfirmEmailModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Potvrzení e-mailu – Flowlio</title>
    <style>
        body { font-family: 'Segoe UI', Helvetica, Arial, sans-serif; margin: 0; min-height: 100vh;
               display: flex; align-items: center; justify-content: center;
               background: linear-gradient(135deg,#1e3a8a,#2563eb); }
        .card { background:#fff; padding:32px; border-radius:14px; width:100%; max-width:380px;
                box-shadow:0 20px 50px rgba(0,0,0,.25); text-align:center; }
        .logo { font-size:22px; font-weight:800; color:#2563eb; margin-bottom:18px; }
        h1 { font-size:22px; margin:0 0 12px; }
        p { font-size:14px; color:#475569; }
        a.btn { display:inline-block; margin-top:18px; padding:11px 20px; border-radius:8px;
                background:#2563eb; color:#fff; font-weight:600; text-decoration:none; }
        .switch { margin-top:18px; font-size:14px; color:#64748b; }
    </style>
</head>
<body>
    <div class="card">
        <div class="logo">₣ Flowlio</div>
        @if (Model.Confirmed)
        {
            <h1>E-mail potvrzen ✓</h1>
            <p>Děkujeme, vaše e-mailová adresa byla ověřena. Teď se můžete přihlásit.</p>
            <a class="btn" href="@Model.LoginUrl">Přihlásit se</a>
        }
        else
        {
            <h1>Odkaz není platný</h1>
            <p>Potvrzovací odkaz je neplatný nebo vypršel. Zkuste registraci znovu nebo si nechte poslat nový odkaz při přihlášení.</p>
            <div class="switch"><a href="/Account/Login">Zpět na přihlášení</a></div>
        }
    </div>
</body>
</html>
