@inherits LayoutComponentBase
@implements IAsyncDisposable
@inject NavigationManager Navigation
@inject LiveNotificationService Live
@inject CurrentUserState CurrentUser
@inject IToastService Toasts

<FluentDesignTheme Mode="_designMode" StorageName="flowlio-theme" />

<FluentToastProvider />
<FluentDialogProvider />
<FluentTooltipProvider />
<FluentMessageBarProvider />
<FluentMenuProvider />

@if (_suspended)
{
    <div style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px;">
        <FluentCard Class="panel" Style="max-width:460px;">
            <div class="empty-state">
                <div class="empty-state-icon">🔒</div>
                <p>Váš přístup do rodiny byl pozastaven.</p>
                <p class="hint">Pokud jde o omyl, kontaktujte prosím správce rodiny.</p>
                <FluentButton Appearance="Appearance.Accent" OnClick="LogOut">Odhlásit se</FluentButton>
            </div>
        </FluentCard>
    </div>
}
else
{
    <div class="page @(_sidebarOpen ? "is-sidebar-open" : "")">
        <aside class="sidebar">
            <NavMenu />
        </aside>

        @if (_sidebarOpen)
        {
            <div class="sidebar-backdrop" @onclick="CloseSidebar"></div>
        }

        <main class="main">
            <header class="topbar">
                <button type="button"
                        class="topbar-burger"
                        aria-label="Otevřít navigaci"
                        aria-expanded="@(_sidebarOpen ? "true" : "false")"
                        @onclick="ToggleSidebar">
                    <span></span><span></span><span></span>
                </button>
                <nav class="topbar-breadcrumb" aria-label="Drobečková navigace">
                    @if (_pageTitle == HomeTitle)
                    {
                        <span class="breadcrumb-current">@HomeTitle</span>
                    }
                    else
                    {
                        <a class="breadcrumb-link" href="">@HomeTitle</a>
                        <span class="breadcrumb-sep">›</span>
                        <span class="breadcrumb-current">@_pageTitle</span>
                    }
                </nav>
                <span class="spacer"></span>
                <ProfileMenu OnThemeChanged="HandleThemeChangedAsync" />
            </header>

            <article class="content">
                @if (!_bannerDismissed && _me is { TwoFactorEnabled: false, Require2faByUtc: { } deadline })
                {
                    <FluentMessageBar Intent="MessageIntent.Warning" Class="twofa-reminder" AllowDismiss="false">
                        Zapněte si dvoufaktorové ověření do @deadline.LocalDateTime.ToString("d.M.yyyy") – po této lhůtě se bez něj nepřihlásíte.
                        <a href="/Account/TwoFactor">Zapnout teď</a>
                        <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => _bannerDismissed = true)">Skrýt</FluentButton>
                    </FluentMessageBar>
                }
                @Body
            </article>

            <footer class="appfooter">
                <span class="appfooter-copy">© @DateTime.Now.Year Flowlio</span>
                <nav class="appfooter-links" aria-label="Právní informace">
                    <a href="terms">Podmínky užívání</a>
                    <a href="privacy">Ochrana soukromí</a>
                    <a href="gdpr">GDPR</a>
                </nav>
            </footer>
        </main>
    </div>
}

@code {
    private const string HomeTitle = "Přehled";
    private DesignThemeModes _designMode = DesignThemeModes.System;
    private string _pageTitle = "";

    private static readonly (string Prefix, string Title)[] _routeTitles =
    [
        ("/transactions",   "Transakce"),
        ("/accounts",       "Účty"),
        ("/budgets",        "Rozpočty a cíle"),
        ("/rules",          "Pravidla"),
        ("/family",         "Rodina"),
        ("/import",         "Import výpisu"),
        ("/administration", "Systémová administrace"),
        ("/terms",          "Podmínky užívání"),
        ("/privacy",        "Ochrana soukromí"),
        ("/gdpr",           "GDPR"),
    ];

    private CurrentUserDto? _me;
    private bool _suspended;
    private bool _bannerDismissed;

    protected override void OnInitialized()
    {
        UpdatePageTitle();
        Navigation.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        CurrentUser.Changed += OnUserChanged;
        await RefreshUserAsync();
    }

    private async Task RefreshUserAsync()
    {
        _me = await CurrentUser.GetAsync();
        _suspended = CurrentUser.IsSuspended;
    }

    private void OnUserChanged() => _ = InvokeAsync(async () =>
    {
        var previous = _me;
        await RefreshUserAsync();
        // Tell the user when an admin changed their access mid-session (but not on the initial load
        // or a suspension, which has its own full-screen message).
        if (!_suspended && previous is not null && _me is not null && AccessDiffers(previous, _me))
            Toasts.ShowWarning(AccessChangeMessage(previous, _me));
        StateHasChanged();
    });

    private static bool AccessDiffers(CurrentUserDto a, CurrentUserDto b) =>
        a.Role != b.Role || a.IsAdmin != b.IsAdmin
        || a.Permissions.Count != b.Permissions.Count || a.Permissions.Except(b.Permissions).Any()
        || a.SystemPermissions.Count != b.SystemPermissions.Count || a.SystemPermissions.Except(b.SystemPermissions).Any();

    private static string AccessChangeMessage(CurrentUserDto prev, CurrentUserDto now)
    {
        var added = now.Permissions.Except(prev.Permissions).Count() + now.SystemPermissions.Except(prev.SystemPermissions).Count();
        var removed = prev.Permissions.Except(now.Permissions).Count() + prev.SystemPermissions.Except(now.SystemPermissions).Count();
        var detail = (added, removed) switch
        {
            ( > 0, > 0) => $" (přidáno {added}, odebráno {removed})",
            ( > 0, 0) => $" (přidáno {added})",
            (0, > 0) => $" (odebráno {removed})",
            _ => "",
        };
        return $"Vaše oprávnění byla změněna administrátorem{detail}.";
    }

    private void LogOut() => Navigation.NavigateToLogout("authentication/logout");

    private bool _sidebarOpen;

    private void ToggleSidebar() => _sidebarOpen = !_sidebarOpen;
    private void CloseSidebar() => _sidebarOpen = false;

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        // Always close the slide-over sidebar after a navigation on mobile;
        // on desktop the sidebar is permanent so the flag is a no-op visually.
        _sidebarOpen = false;

        var previous = _pageTitle;
        UpdatePageTitle();
        if (previous != _pageTitle)
            InvokeAsync(StateHasChanged);
    }

    private void UpdatePageTitle()
    {
        var path = "/" + Navigation.ToBaseRelativePath(Navigation.Uri).TrimEnd('/');
        if (path.Contains('?')) path = path[..path.IndexOf('?')];
        if (path.Contains('#')) path = path[..path.IndexOf('#')];

        foreach (var (prefix, title) in _routeTitles)
        {
            if (path.StartsWith(prefix, StringComparison.OrdinalIgnoreCase))
            {
                _pageTitle = title;
                return;
            }
        }
        _pageTitle = HomeTitle;
    }

    private Task HandleThemeChangedAsync(string theme)
    {
        var next = theme switch
        {
            "light" => DesignThemeModes.Light,
            "dark"  => DesignThemeModes.Dark,
            _       => DesignThemeModes.System,
        };
        if (next == _designMode)
            return Task.CompletedTask;
        _designMode = next;
        StateHasChanged();
        return Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        Live.ImportCompleted += OnImportCompleted;
        Live.AccessChanged += OnAccessChanged;
        Live.Notice += OnNotice;
        try
        {
            await Live.StartAsync();
        }
        catch
        {
            // The hub is unavailable when not authenticated yet; the connection is retried on next load.
        }
    }

    private void OnImportCompleted(ImportCompletedNotification notification)
    {
        InvokeAsync(() =>
            Toasts.ShowSuccess($"Import dokončen: {notification.ImportedCount} nových, {notification.DuplicateCount} duplicit."));
    }

    private void OnAccessChanged() => _ = InvokeAsync(CurrentUser.RefreshAsync);

    private void OnNotice(NoticeNotification notice) => InvokeAsync(() =>
    {
        switch (notice.Severity)
        {
            case "success": Toasts.ShowSuccess(notice.Message); break;
            case "error": Toasts.ShowError(notice.Message); break;
            case "warning": Toasts.ShowWarning(notice.Message); break;
            default: Toasts.ShowInfo(notice.Message); break;
        }
    });

    public async ValueTask DisposeAsync()
    {
        Navigation.LocationChanged -= OnLocationChanged;
        CurrentUser.Changed -= OnUserChanged;
        Live.ImportCompleted -= OnImportCompleted;
        Live.AccessChanged -= OnAccessChanged;
        Live.Notice -= OnNotice;
        await Live.DisposeAsync();
    }
}
