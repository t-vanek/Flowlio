@inject CurrentUserState CurrentUser
@implements IDisposable

<div class="nav-brand">
    <span class="nav-logo">₣</span>
    <span class="nav-brand-text">Flowlio</span>
</div>

<nav class="nav-list">
    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
        <span class="nav-icon">📊</span> Přehled
    </NavLink>
    <NavLink class="nav-link" href="transactions">
        <span class="nav-icon">💳</span> Transakce
    </NavLink>
    @if (_canManageTransactions)
    {
        <NavLink class="nav-link" href="pohyby">
            <span class="nav-icon">📝</span> Pohyby
        </NavLink>
    }
    <NavLink class="nav-link" href="accounts">
        <span class="nav-icon">🏦</span> Účty
    </NavLink>
    @if (_canManageMembers)
    {
        <NavLink class="nav-link" href="family">
            <span class="nav-icon">👪</span> Rodina
        </NavLink>
    }
    @if (_canImport)
    {
        <NavLink class="nav-link" href="import">
            <span class="nav-icon">📥</span> Import výpisu
        </NavLink>
    }
    @if (_canAdminister)
    {
        <NavLink class="nav-link" href="administration">
            <span class="nav-icon">⚙️</span> Administrace
        </NavLink>
    }
</nav>

@code {
    private bool _canManageMembers;
    private bool _canManageTransactions;
    private bool _canImport;
    private bool _canAdminister;

    protected override async Task OnInitializedAsync()
    {
        CurrentUser.Changed += OnChanged;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        var me = await CurrentUser.GetAsync();
        _canManageMembers = me?.Can(Permission.ManageMembers) ?? false;
        _canManageTransactions = me?.Can(Permission.ManageTransactions) ?? false;
        _canImport = me?.Can(Permission.ImportStatements) ?? false;
        _canAdminister = (me?.SystemPermissions.Count > 0)
            || (me?.Can(Permission.ManageRoles) ?? false)
            || (me?.Can(Permission.ManageFamily) ?? false);
    }

    private void OnChanged() => _ = InvokeAsync(async () =>
    {
        await LoadAsync();
        StateHasChanged();
    });

    public void Dispose() => CurrentUser.Changed -= OnChanged;
}
