@inject CurrentUserState CurrentUser
@implements IDisposable

<div class="nav-brand">
    <span class="nav-logo">₣</span>
    <span class="nav-brand-text">Flowlio</span>
</div>

<nav class="nav-list">
    @* Finances: overview, transactions, accounts and statement import belong together. *@
    @if (_canViewFinances)
    {
        <NavLink class="nav-link" href="" Match="NavLinkMatch.All" title="Přehled">
            <span class="nav-icon">📊</span>
            <span class="nav-link-label">Přehled</span>
        </NavLink>
        <NavLink class="nav-link" href="transactions" title="Transakce">
            <span class="nav-icon">💳</span>
            <span class="nav-link-label">Transakce</span>
        </NavLink>
        <NavLink class="nav-link" href="accounts" title="Účty">
            <span class="nav-icon">🏦</span>
            <span class="nav-link-label">Účty</span>
        </NavLink>
        <NavLink class="nav-link" href="budgets" title="Rozpočty a cíle">
            <span class="nav-icon">🎯</span>
            <span class="nav-link-label">Rozpočty a cíle</span>
        </NavLink>
    }
    @if (_canImport)
    {
        <NavLink class="nav-link" href="import" title="Import výpisu">
            <span class="nav-icon">📥</span>
            <span class="nav-link-label">Import výpisu</span>
        </NavLink>
        <NavLink class="nav-link" href="bank-connect" title="Připojení banky">
            <span class="nav-icon">🔗</span>
            <span class="nav-link-label">Připojení banky</span>
        </NavLink>
    }
    @if (_canManageRules)
    {
        <NavLink class="nav-link" href="triage" title="Pohyby k zařazení">
            <span class="nav-icon">📂</span>
            <span class="nav-link-label">K zařazení</span>
        </NavLink>
        <NavLink class="nav-link" href="rules" title="Pravidla kategorizace">
            <span class="nav-icon">🏷️</span>
            <span class="nav-link-label">Pravidla</span>
        </NavLink>
    }

    @if (_hasFinance && _hasFamily)
    {
        <hr class="nav-divider" />
    }

    @* Family: members and family administration. *@
    @if (_canManageMembers)
    {
        <NavLink class="nav-link" href="family" title="Rodina">
            <span class="nav-icon">👪</span>
            <span class="nav-link-label">Rodina</span>
        </NavLink>
    }
    @if (_canFamilyAdmin)
    {
        <NavLink class="nav-link" href="family/manage" title="Správa rodiny">
            <span class="nav-icon">🛡️</span>
            <span class="nav-link-label">Správa rodiny</span>
        </NavLink>
    }

    @* System administration is cross-family; keep it apart at the very bottom. *@
    @if (_canAdminister)
    {
        <div class="nav-bottom">
            @if (_hasFinance || _hasFamily)
            {
                <hr class="nav-divider" />
            }
            <NavLink class="nav-link" href="administration" title="Systémová administrace">
                <span class="nav-icon">⚙️</span>
                <span class="nav-link-label">Systémová administrace</span>
            </NavLink>
        </div>
    }
</nav>

@code {
    private bool _canViewFinances;
    private bool _canManageMembers;
    private bool _canImport;
    private bool _canManageRules;
    private bool _canFamilyAdmin;
    private bool _canAdminister;

    private bool _hasFinance => _canViewFinances || _canImport || _canManageRules;
    private bool _hasFamily => _canManageMembers || _canFamilyAdmin;

    protected override async Task OnInitializedAsync()
    {
        CurrentUser.Changed += OnChanged;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        var me = await CurrentUser.GetAsync();
        _canViewFinances = me?.Can(Permission.ViewFinances) ?? false;
        _canManageMembers = me?.Can(Permission.ManageMembers) ?? false;
        _canImport = me?.Can(Permission.ImportStatements) ?? false;
        _canManageRules = me?.Can(Permission.ManageTransactions) ?? false;
        _canFamilyAdmin = (me?.Can(Permission.ManageRoles) ?? false)
                       || (me?.Can(Permission.ManageFamily) ?? false);
        _canAdminister = me?.SystemPermissions.Count > 0;
    }

    private void OnChanged() => _ = InvokeAsync(async () =>
    {
        await LoadAsync();
        StateHasChanged();
    });

    public void Dispose() => CurrentUser.Changed -= OnChanged;
}
