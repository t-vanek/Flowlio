@inject CurrentUserState CurrentUser

<div class="nav-brand">
    <span class="nav-logo">₣</span>
    <span class="nav-brand-text">Flowlio</span>
</div>

<nav class="nav-list">
    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
        <span class="nav-icon">📊</span> Přehled
    </NavLink>
    <NavLink class="nav-link" href="transactions">
        <span class="nav-icon">💳</span> Transakce
    </NavLink>
    <NavLink class="nav-link" href="accounts">
        <span class="nav-icon">🏦</span> Účty
    </NavLink>
    @if (_canManageMembers)
    {
        <NavLink class="nav-link" href="family">
            <span class="nav-icon">👪</span> Rodina
        </NavLink>
    }
    @if (_canImport)
    {
        <NavLink class="nav-link" href="import">
            <span class="nav-icon">📥</span> Import výpisu
        </NavLink>
    }
</nav>

@code {
    private bool _canManageMembers;
    private bool _canImport;

    protected override async Task OnInitializedAsync()
    {
        var me = await CurrentUser.GetAsync();
        _canManageMembers = me?.Can(Permission.ManageMembers) ?? false;
        _canImport = me?.Can(Permission.ImportStatements) ?? false;
    }
}
