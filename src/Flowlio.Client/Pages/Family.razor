@page "/family"
@attribute [Authorize]
@inject FlowlioApi Api
@inject CurrentUserState CurrentUser
@inject IDialogService Dialogs
@inject IToastService Toasts

<PageTitle>Rodina – Flowlio</PageTitle>

<h1 class="page-title">Rodina</h1>

<div class="panel-grid">
    @if (_canManage)
    {
    <FluentCard Class="panel">
        <h2 class="panel-title">Přidat člena</h2>
        <p class="muted">Pozvěte manžela/manželku jako dospělého, přidejte pozorovatele, nebo založte dětský účet pod opatrovníkem.</p>
        <EditForm Model="_model" OnValidSubmit="CreateAsync">
            <DataAnnotationsValidator />
            <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
                <div>
                    <FluentTextField @bind-Value="_model.DisplayName" Label="Jméno" Style="width:100%" Placeholder="Jana Nováková" />
                    <FluentValidationMessage For="@(() => _model.DisplayName)" />
                </div>

                <FluentSelect TOption="string" @bind-Value="_roleValue" Label="Role" Style="width:100%">
                    <FluentOption TOption="string" Value="@(((int)MemberRole.Adult).ToString())">Dospělý (manžel/ka)</FluentOption>
                    <FluentOption TOption="string" Value="@(((int)MemberRole.Viewer).ToString())">Pozorovatel (jen čtení)</FluentOption>
                    <FluentOption TOption="string" Value="@(((int)MemberRole.Child).ToString())">Dítě</FluentOption>
                </FluentSelect>

                @if (SelectedRole == MemberRole.Child)
                {
                    <FluentSelect TOption="string" @bind-Value="_guardianValue" Label="Opatrovník" Style="width:100%">
                        @foreach (var g in Guardians)
                        {
                            <FluentOption TOption="string" Value="@g.Id.ToString()">@g.DisplayName</FluentOption>
                        }
                    </FluentSelect>
                    <p class="muted">Opatrovník má plnou kontrolu nad účty a kartami dítěte. E-mail je volitelný – starší dítě se může přihlásit, malé spravuje rodič.</p>
                }

                <FluentTextField @bind-Value="_email" Label="@(SelectedRole == MemberRole.Child ? "E-mail (volitelný)" : "E-mail pro pozvánku")" Style="width:100%" Placeholder="jana@example.com" />

                <FluentButton Type="ButtonType.Submit" Appearance="Appearance.Accent" Loading="_busy">Přidat člena</FluentButton>

                @if (_error is not null)
                {
                    <FluentMessageBar Intent="MessageIntent.Error">@_error</FluentMessageBar>
                }
                @if (_lastInvite is not null)
                {
                    <FluentMessageBar Intent="MessageIntent.Success">
                        Pozvánka vytvořena. Odešlete tento odkaz @_lastInvite.MemberName:
                    </FluentMessageBar>
                    <FluentTextField Value="@_lastInvite.InviteUrl" ReadOnly="true" Style="width:100%" />
                }
            </FluentStack>
        </EditForm>
    </FluentCard>
    }

    <FluentCard Class="panel">
        <h2 class="panel-title">Členové rodiny</h2>
        @if (_members is null)
        {
            <FluentProgressRing />
        }
        else if (_members.Count == 0)
        {
            <p class="muted">Zatím žádní členové.</p>
        }
        else
        {
            @foreach (var m in _members)
            {
                <div class="account-row">
                    <div>
                        <div class="account-name">
                            @m.DisplayName
                            @if (m.IsCurrentUser)
                            {
                                <span class="muted">(vy)</span>
                            }
                            @if (!m.IsActive)
                            {
                                <span class="muted">· neaktivní</span>
                            }
                        </div>
                        <div class="muted">
                            @RoleLabel(m.Role) · @StatusLabel(m.Status)
                            @if (m.GuardianName is not null)
                            {
                                <text> · opatrovník: @m.GuardianName</text>
                            }
                            @if (!string.IsNullOrWhiteSpace(m.Email))
                            {
                                <text> · @m.Email</text>
                            }
                        </div>
                    </div>
                    <div>
                        @if (_canManage && m.Status == MemberStatus.Pending)
                        {
                            <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => ReinviteAsync(m.Id))">Znovu pozvat</FluentButton>
                        }
                        @if (_canManage)
                        {
                            <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => BeginEdit(m))">Upravit</FluentButton>
                        }
                        @if (_canManage && !m.IsCurrentUser && m.Role != MemberRole.Owner)
                        {
                            <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => SetActiveAsync(m, !m.IsActive))">
                                @(m.IsActive ? "Deaktivovat" : "Aktivovat")
                            </FluentButton>
                            <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => DeleteAsync(m.Id))">Odebrat</FluentButton>
                        }
                    </div>
                </div>

                @if (_editingId == m.Id)
                {
                    <div class="member-edit">
                        <EditForm Model="_editModel" OnValidSubmit="@(() => SaveEditAsync(m))">
                            <DataAnnotationsValidator />
                            <FluentStack Orientation="Orientation.Vertical" VerticalGap="10">
                                <div>
                                    <FluentTextField @bind-Value="_editModel.DisplayName" Label="Jméno" Style="width:100%" />
                                    <FluentValidationMessage For="@(() => _editModel.DisplayName)" />
                                </div>
                                <FluentTextField @bind-Value="_editEmail" Label="E-mail" Style="width:100%" />
                                @if (m.Role != MemberRole.Owner)
                                {
                                    <FluentSelect TOption="string" @bind-Value="_editRoleValue" Label="Role" Style="width:100%">
                                        <FluentOption TOption="string" Value="@(((int)MemberRole.Adult).ToString())">Dospělý</FluentOption>
                                        <FluentOption TOption="string" Value="@(((int)MemberRole.Viewer).ToString())">Pozorovatel</FluentOption>
                                        <FluentOption TOption="string" Value="@(((int)MemberRole.Child).ToString())">Dítě</FluentOption>
                                    </FluentSelect>
                                    @if (EditRole == MemberRole.Child)
                                    {
                                        <FluentSelect TOption="string" @bind-Value="_editGuardianValue" Label="Opatrovník" Style="width:100%">
                                            @foreach (var g in Guardians.Where(x => x.Id != m.Id))
                                            {
                                                <FluentOption TOption="string" Value="@g.Id.ToString()">@g.DisplayName</FluentOption>
                                            }
                                        </FluentSelect>
                                    }
                                }
                                else
                                {
                                    <p class="muted">Roli vlastníka změníte v Administraci → Rodina (převod vlastnictví).</p>
                                }
                                <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8">
                                    <FluentButton Type="ButtonType.Submit" Appearance="Appearance.Accent">Uložit</FluentButton>
                                    <FluentButton Type="ButtonType.Button" Appearance="Appearance.Stealth" OnClick="CancelEdit">Zrušit</FluentButton>
                                </FluentStack>
                            </FluentStack>
                        </EditForm>
                    </div>
                }
            }
        }

        @if (_invitations is { Count: > 0 })
        {
            <h2 class="panel-title" style="margin-top:20px;">Čekající pozvánky</h2>
            @foreach (var inv in _invitations)
            {
                <div class="account-row">
                    <div>
                        <div class="account-name">@inv.MemberName</div>
                        <div class="muted">@inv.Email · platí do @Formatting.Date(inv.ExpiresAt)</div>
                    </div>
                    <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => RevokeAsync(inv.Id))">Zrušit</FluentButton>
                </div>
            }
        }
    </FluentCard>
</div>

@code {
    private IReadOnlyList<FamilyMemberDto>? _members;
    private IReadOnlyList<InvitationDto>? _invitations;
    private CreateMemberRequest _model = new();
    private string _email = "";
    private string _roleValue = ((int)MemberRole.Adult).ToString();
    private string _guardianValue = "";
    private bool _busy;
    private string? _error;
    private InvitationDto? _lastInvite;
    private bool _canManage;

    private Guid? _editingId;
    private UpdateMemberRequest _editModel = new();
    private string _editEmail = "";
    private string _editRoleValue = ((int)MemberRole.Adult).ToString();
    private string _editGuardianValue = "";

    private MemberRole SelectedRole => (MemberRole)int.Parse(_roleValue);
    private MemberRole EditRole => (MemberRole)int.Parse(_editRoleValue);

    private IEnumerable<FamilyMemberDto> Guardians =>
        _members?.Where(m => m.Role is MemberRole.Owner or MemberRole.Adult) ?? [];

    protected override async Task OnInitializedAsync()
    {
        _canManage = await CurrentUser.CanAsync(Permission.ManageMembers);
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _members = await Api.GetMembersAsync();
        _invitations = await Api.GetInvitationsAsync();
        if (string.IsNullOrEmpty(_guardianValue))
            _guardianValue = Guardians.FirstOrDefault()?.Id.ToString() ?? "";
    }

    private async Task CreateAsync()
    {
        _error = null;
        _lastInvite = null;

        Guid? guardianId = null;
        if (SelectedRole == MemberRole.Child)
        {
            if (!Guid.TryParse(_guardianValue, out var gid))
            {
                _error = "Vyberte opatrovníka.";
                return;
            }
            guardianId = gid;
        }

        _busy = true;
        try
        {
            _model.Email = string.IsNullOrWhiteSpace(_email) ? null : _email.Trim();
            _model.Role = SelectedRole;
            _model.GuardianMemberId = guardianId;
            var result = await Api.CreateMemberAsync(_model);

            if (result is null)
            {
                _error = "Člena se nepodařilo přidat.";
                return;
            }

            _lastInvite = result.Invitation;
            Toasts.ShowSuccess("Člen byl přidán.");
            _model = new();
            _email = "";
            await LoadAsync();
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ReinviteAsync(Guid memberId)
    {
        _error = null;
        var invite = await Api.ReinviteMemberAsync(memberId);
        if (invite is null)
            _error = "Pozvánku se nepodařilo vytvořit (chybí u člena e-mail?).";
        else
        {
            _lastInvite = invite;
            Toasts.ShowSuccess("Pozvánka byla vytvořena.");
        }
        await LoadAsync();
    }

    private async Task DeleteAsync(Guid memberId)
    {
        _error = null;
        var name = _members?.FirstOrDefault(x => x.Id == memberId)?.DisplayName ?? "člena";
        if (!await Dialogs.ConfirmAsync(
            $"Opravdu odebrat člena: {name}? Tuto akci nelze vrátit zpět.",
            "Odebrat", "Odebrání člena"))
            return;

        if (await Api.DeleteMemberAsync(memberId))
            Toasts.ShowSuccess("Člen byl odebrán.");
        else
        {
            _error = "Člena nelze odebrat (je opatrovníkem dítěte?).";
            Toasts.ShowError("Člena se nepodařilo odebrat.");
        }
        await LoadAsync();
    }

    private async Task RevokeAsync(Guid invitationId)
    {
        var who = _invitations?.FirstOrDefault(i => i.Id == invitationId)?.MemberName ?? "pozvánku";
        if (!await Dialogs.ConfirmAsync(
            $"Opravdu zrušit pozvánku pro: {who}?",
            "Zrušit pozvánku", "Zrušení pozvánky", cancelLabel: "Zpět"))
            return;

        if (await Api.RevokeInvitationAsync(invitationId))
            Toasts.ShowSuccess("Pozvánka byla zrušena.");
        else
            Toasts.ShowError("Pozvánku se nepodařilo zrušit.");
        await LoadAsync();
    }

    private void BeginEdit(FamilyMemberDto m)
    {
        _error = null;
        _editingId = m.Id;
        _editModel = new UpdateMemberRequest { DisplayName = m.DisplayName, Version = m.Version };
        _editEmail = m.Email ?? "";
        _editRoleValue = ((int)(m.Role == MemberRole.Owner ? MemberRole.Adult : m.Role)).ToString();
        _editGuardianValue = m.GuardianMemberId?.ToString()
            ?? Guardians.FirstOrDefault(g => g.Id != m.Id)?.Id.ToString() ?? "";
    }

    private void CancelEdit() => _editingId = null;

    private async Task SaveEditAsync(FamilyMemberDto m)
    {
        _error = null;

        var role = m.Role == MemberRole.Owner ? MemberRole.Owner : EditRole;
        Guid? guardianId = null;
        if (role == MemberRole.Child)
        {
            if (!Guid.TryParse(_editGuardianValue, out var gid))
            {
                _error = "Vyberte opatrovníka.";
                return;
            }
            guardianId = gid;
        }

        _editModel.Email = string.IsNullOrWhiteSpace(_editEmail) ? null : _editEmail.Trim();
        _editModel.Role = role;
        _editModel.GuardianMemberId = guardianId;
        var result = await Api.UpdateMemberAsync(m.Id, _editModel);

        if (result == SaveStatus.Conflict)
        {
            _error = "Člen byl mezitím změněn jiným uživatelem. Načetl jsem aktuální verzi, zkuste úpravu znovu.";
            _editingId = null;
            await LoadAsync();
            return;
        }
        if (result != SaveStatus.Success)
        {
            _error = "Úpravu se nepodařilo uložit.";
            return;
        }

        _editingId = null;
        Toasts.ShowSuccess("Změny člena byly uloženy.");
        await LoadAsync();
    }

    private async Task SetActiveAsync(FamilyMemberDto m, bool active)
    {
        _error = null;
        if (!active)
        {
            if (!await Dialogs.ConfirmAsync(
                $"Opravdu deaktivovat člena: {m.DisplayName}? Ztratí přístup, dokud ho znovu neaktivujete.",
                "Deaktivovat", "Deaktivace člena"))
                return;
        }

        if (await Api.SetMemberActiveAsync(m.Id, active))
            Toasts.ShowSuccess(active ? "Člen byl aktivován." : "Člen byl deaktivován.");
        else
            Toasts.ShowError("Změnu stavu se nepodařilo uložit.");
        await LoadAsync();
    }

    private static string RoleLabel(MemberRole role) => role switch
    {
        MemberRole.Owner => "Vlastník",
        MemberRole.Adult => "Dospělý",
        MemberRole.Viewer => "Pozorovatel",
        MemberRole.Child => "Dítě",
        _ => role.ToString(),
    };

    private static string StatusLabel(MemberStatus status) => status switch
    {
        MemberStatus.Active => "aktivní",
        MemberStatus.Pending => "čeká na přijetí",
        MemberStatus.Managed => "spravováno rodičem",
        _ => status.ToString(),
    };
}
