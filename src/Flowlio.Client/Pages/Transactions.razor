@page "/transactions"
@attribute [Authorize]
@implements IAsyncDisposable
@inject FlowlioApi Api
@inject CurrentUserState CurrentUser
@inject IDialogService Dialogs
@inject IToastService Toasts
@inject IJSRuntime JS

<PageTitle>Transakce – Flowlio</PageTitle>

<h1 class="page-title">Transakce</h1>

<div class="toolbar">
    <FluentSearch @bind-Value="_search" @bind-Value:after="ApplyClientFiltersAsync"
                  Immediate="true" ImmediateDelay="250"
                  Placeholder="Hledat protistranu, popis nebo VS…" Class="toolbar-search" />

    @if (_canManage && _accounts.Count > 0)
    {
        <div class="toolbar-actions">
            <FluentButton Appearance="Appearance.Neutral" OnClick="OpenCreate">+ Přidat pohyb</FluentButton>
        </div>
    }
</div>

<div class="toolbar">
    <FluentSelect TOption="string" @bind-Value="_accountValue" @bind-Value:after="ApplyClientFiltersAsync" Label="Účet">
        <FluentOption TOption="string" Value="">Všechny účty</FluentOption>
        @foreach (var a in _accounts)
        {
            <FluentOption TOption="string" Value="@a.Id.ToString()">@a.Name</FluentOption>
        }
    </FluentSelect>

    <FluentSelect TOption="string" @bind-Value="_categoryValue" @bind-Value:after="ApplyClientFiltersAsync" Label="Kategorie">
        <FluentOption TOption="string" Value="">Všechny kategorie</FluentOption>
        @foreach (var c in _categories)
        {
            <FluentOption TOption="string" Value="@c.Id.ToString()">@c.Name</FluentOption>
        }
    </FluentSelect>

    <FluentSelect TOption="string" @bind-Value="_typeValue" @bind-Value:after="ApplyClientFiltersAsync" Label="Typ">
        <FluentOption TOption="string" Value="">Vše</FluentOption>
        <FluentOption TOption="string" Value="@(((int)TransactionDirection.Incoming).ToString())">Příjmy</FluentOption>
        <FluentOption TOption="string" Value="@(((int)TransactionDirection.Outgoing).ToString())">Výdaje</FluentOption>
    </FluentSelect>

    <FluentSelect TOption="string" @bind-Value="_periodValue" @bind-Value:after="OnPeriodChangedAsync" Label="Období">
        <FluentOption TOption="string" Value="">Celé období</FluentOption>
        <FluentOption TOption="string" Value="thisMonth">Tento měsíc</FluentOption>
        <FluentOption TOption="string" Value="lastMonth">Minulý měsíc</FluentOption>
        <FluentOption TOption="string" Value="last30">Posledních 30 dní</FluentOption>
        <FluentOption TOption="string" Value="thisYear">Tento rok</FluentOption>
        @if (_periodValue == "custom")
        {
            <FluentOption TOption="string" Value="custom">Vlastní</FluentOption>
        }
    </FluentSelect>

    <div class="filter-range">
        <span class="filter-label">Od</span>
        <FluentDatePicker @bind-Value="_dateFrom" @bind-Value:after="OnDateEditedAsync" Culture="Cz" />
        <span class="filter-label">Do</span>
        <FluentDatePicker @bind-Value="_dateTo" @bind-Value:after="OnDateEditedAsync" Culture="Cz" />
    </div>
</div>

@if (_showEditor)
{
    <FluentCard Class="panel">
        <h2 class="panel-title">@(_editId is null ? "Nový pohyb" : "Úprava pohybu")</h2>
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
            @if (_editId is null)
            {
                <FluentSelect TOption="string" @bind-Value="_formAccount" Label="Účet" Style="width:100%">
                    @foreach (var a in _accounts)
                    {
                        <FluentOption TOption="string" Value="@a.Id.ToString()">@a.Name</FluentOption>
                    }
                </FluentSelect>
            }

            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8">
                <div>
                    <label class="field-label">Datum zaúčtování</label>
                    <input type="date" class="date-input" @bind="_formBooking" />
                </div>
                <div>
                    <label class="field-label">Datum splatnosti (volitelné)</label>
                    <input type="date" class="date-input" @bind="_formValue" />
                </div>
                <div style="width:200px">
                    <label class="field-label">Částka (záporná = výdaj)</label>
                    <MoneyField @bind-Value="_formAmount" />
                </div>
                <FluentTextField @bind-Value="_formCurrency" Label="Měna" Style="width:90px" />
            </FluentStack>

            <FluentTextField @bind-Value="_formCounterparty" Label="Protistrana" Style="width:100%" />
            <FluentTextField @bind-Value="_formCounterpartyAccount" Label="Číslo účtu protistrany" Style="width:100%" />

            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8">
                <FluentTextField @bind-Value="_formVs" Label="VS" Style="width:140px" />
                <FluentTextField @bind-Value="_formCs" Label="KS" Style="width:140px" />
                <FluentTextField @bind-Value="_formSs" Label="SS" Style="width:140px" />
            </FluentStack>

            <FluentTextField @bind-Value="_formDescription" Label="Popis" Style="width:100%" />
            <FluentTextField @bind-Value="_formNote" Label="Poznámka" Style="width:100%" />

            <FluentSelect TOption="string" @bind-Value="_formCategory" Label="Kategorie" Style="width:100%">
                <FluentOption TOption="string" Value="">(bez kategorie)</FluentOption>
                @foreach (var c in _categories)
                {
                    <FluentOption TOption="string" Value="@c.Id.ToString()">@c.Name</FluentOption>
                }
            </FluentSelect>

            @if (_formError is not null)
            {
                <FluentMessageBar Intent="MessageIntent.Error">@_formError</FluentMessageBar>
            }

            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8">
                <FluentButton Appearance="Appearance.Accent" OnClick="SaveAsync" Loading="_saving">Uložit</FluentButton>
                <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => _showEditor = false)">Zrušit</FluentButton>
            </FluentStack>
        </FluentStack>
    </FluentCard>
}

@if (_loading)
{
    <FluentProgressRing />
}
else if (_rows.Count == 0)
{
    <FluentCard Class="panel">
        <div class="empty-state">
            <div class="empty-state-icon">🗒️</div>
            <p>Žádné transakce k zobrazení.</p>
            <p class="hint">Naimportujte výpis nebo přidejte pohyb ručně.</p>
            @if (_canManage && _accounts.Count > 0)
            {
                <FluentButton Appearance="Appearance.Accent" OnClick="OpenCreate">+ Přidat pohyb</FluentButton>
            }
        </div>
    </FluentCard>
}
else
{
    <div class="toolbar">
        <FluentSelect TOption="string" @bind-Value="_groupValue" @bind-Value:after="GroupChangedAsync" Label="Seskupit">
            <FluentOption TOption="string" Value="">Bez seskupení</FluentOption>
            <FluentOption TOption="string" Value="category">Podle kategorie</FluentOption>
            <FluentOption TOption="string" Value="month">Podle měsíce</FluentOption>
        </FluentSelect>
        <span class="muted">Celkem @_rows.Count pohybů</span>
        <div class="toolbar-actions">
            @if (HasActiveFilters)
            {
                <FluentButton Appearance="Appearance.Stealth" OnClick="ClearFiltersAsync">Zrušit filtry</FluentButton>
            }
            <FluentButton Appearance="Appearance.Stealth" OnClick="ExportCsvAsync">Export CSV</FluentButton>
        </div>
    </div>
    <FluentCard Class="panel no-pad">
        <div id="tx-grid"></div>
    </FluentCard>
}

@code {
    private List<TransactionDto> _rows = [];
    private Dictionary<Guid, TransactionDto> _byId = [];
    private IReadOnlyList<BankAccountDto> _accounts = [];
    private IReadOnlyList<CategoryDto> _categories = [];
    private Dictionary<Guid, string> _categoryColors = [];
    private bool _canManage;
    private bool _loading = true;

    // Grid (Tabulator) state
    private DotNetObjectReference<Transactions>? _gridRef;
    private bool _renderPending;
    private string _groupValue = "";

    private static readonly System.Globalization.CultureInfo Cz = new("cs-CZ");

    // Filters (applied client-side via Tabulator)
    private string _search = "";
    private string _accountValue = "";
    private string _categoryValue = "";
    private string _typeValue = "";
    private string _periodValue = "";
    private DateTime? _dateFrom;
    private DateTime? _dateTo;

    // Manual movement editor
    private bool _showEditor;
    private bool _saving;
    private Guid? _editId;
    private string? _formError;
    private string _formAccount = "";
    private DateOnly _formBooking = DateOnly.FromDateTime(DateTime.Today);
    private DateOnly? _formValue;
    private decimal _formAmount;
    private string _formCurrency = "CZK";
    private string _formCounterparty = "";
    private string _formCounterpartyAccount = "";
    private string _formVs = "";
    private string _formCs = "";
    private string _formSs = "";
    private string _formDescription = "";
    private string _formNote = "";
    private string _formCategory = "";

    protected override async Task OnInitializedAsync()
    {
        _canManage = await CurrentUser.CanAsync(Permission.ManageTransactions);
        _accounts = await Api.GetAccountsAsync();
        _categories = await Api.GetCategoriesAsync();
        _categoryColors = _categories.ToDictionary(c => c.Id, c => c.Color);
        await LoadAsync();
    }

    // Loads the whole family transaction set (the server caps pageSize at 200, so we
    // page through it). Tabulator then owns pagination, sorting, grouping, the footer
    // sum, CSV export and — see ApplyClientFiltersAsync — instant client-side filtering.
    private async Task LoadAsync()
    {
        _loading = true;
        StateHasChanged();

        var all = new List<TransactionDto>();
        const int size = 200;
        for (var page = 1; page <= 200; page++)
        {
            var result = await Api.GetTransactionsAsync(page: page, pageSize: size);
            if (result is null || result.Items.Count == 0)
                break;
            all.AddRange(result.Items);
            if (all.Count >= result.TotalCount)
                break;
        }

        _rows = all;
        _byId = all.ToDictionary(t => t.Id);
        _loading = false;
        _renderPending = true;
        StateHasChanged();
    }

    private bool HasActiveFilters =>
        !string.IsNullOrEmpty(_search) || _accountValue != "" || _categoryValue != ""
        || _typeValue != "" || _dateFrom is not null || _dateTo is not null;

    // Pushes the current filter values into Tabulator — no server round-trip, and the
    // footer sum / pagination follow the filtered set instantly.
    private async Task ApplyClientFiltersAsync()
    {
        var type = _typeValue == ((int)TransactionDirection.Incoming).ToString() ? "in"
            : _typeValue == ((int)TransactionDirection.Outgoing).ToString() ? "out" : "";

        await JS.InvokeVoidAsync("flowlioGrid.setFilters", "tx-grid", new
        {
            search = _search ?? "",
            accountId = _accountValue,
            categoryId = _categoryValue,
            type,
            dateFrom = _dateFrom is { } f ? f.ToString("yyyy-MM-dd") : "",
            dateTo = _dateTo is { } t ? t.ToString("yyyy-MM-dd") : "",
        });
    }

    private Task OnDateEditedAsync()
    {
        _periodValue = _dateFrom is null && _dateTo is null ? "" : "custom";
        return ApplyClientFiltersAsync();
    }

    private Task OnPeriodChangedAsync()
    {
        var today = DateTime.Today;
        switch (_periodValue)
        {
            case "thisMonth":
                _dateFrom = new DateTime(today.Year, today.Month, 1);
                _dateTo = _dateFrom.Value.AddMonths(1).AddDays(-1);
                break;
            case "lastMonth":
                var lm = new DateTime(today.Year, today.Month, 1).AddMonths(-1);
                _dateFrom = lm;
                _dateTo = lm.AddMonths(1).AddDays(-1);
                break;
            case "last30":
                _dateFrom = today.AddDays(-30);
                _dateTo = today;
                break;
            case "thisYear":
                _dateFrom = new DateTime(today.Year, 1, 1);
                _dateTo = new DateTime(today.Year, 12, 31);
                break;
            default: // "" (celé období) or "custom"
                if (_periodValue != "custom")
                {
                    _dateFrom = null;
                    _dateTo = null;
                }
                break;
        }
        return ApplyClientFiltersAsync();
    }

    private Task ClearFiltersAsync()
    {
        _search = "";
        _accountValue = "";
        _categoryValue = "";
        _typeValue = "";
        _periodValue = "";
        _dateFrom = null;
        _dateTo = null;
        return ApplyClientFiltersAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            _gridRef ??= DotNetObjectReference.Create(this);

        if (_renderPending && !_loading)
        {
            _renderPending = false;
            if (_rows.Count > 0)
                await RenderGridAsync();
            else
                await JS.InvokeVoidAsync("flowlioGrid.destroy", "tx-grid");
        }
    }

    private async Task RenderGridAsync()
    {
        var data = _rows.Select(t => new
        {
            id = t.Id.ToString(),
            accountId = t.BankAccountId.ToString(),
            categoryId = t.CategoryId?.ToString() ?? "",
            bookingDate = t.BookingDate.ToString("yyyy-MM-dd"),
            counterparty = t.CounterpartyName ?? "",
            categoryName = t.CategoryName ?? "",
            categoryColor = CategoryColor(t.CategoryId),
            description = t.Description ?? "",
            vs = t.VariableSymbol ?? "",
            amount = (double)t.Amount,
        });

        await JS.InvokeVoidAsync("flowlioGrid.render", "tx-grid", data,
            new { canManage = _canManage, groupBy = _groupValue, pageSize = 50 }, _gridRef);

        // Re-applies any active filters after a (re)render, e.g. after save/delete.
        if (HasActiveFilters)
            await ApplyClientFiltersAsync();
    }

    private async Task GroupChangedAsync() =>
        await JS.InvokeVoidAsync("flowlioGrid.setGroup", "tx-grid", _groupValue);

    private async Task ExportCsvAsync() =>
        await JS.InvokeVoidAsync("flowlioGrid.exportCsv", "tx-grid");

    [JSInvokable]
    public void GridEdit(string id)
    {
        if (Guid.TryParse(id, out var gid) && _byId.TryGetValue(gid, out var t))
        {
            OpenEdit(t);
            StateHasChanged();
        }
    }

    [JSInvokable]
    public async Task GridDelete(string id)
    {
        if (Guid.TryParse(id, out var gid) && _byId.TryGetValue(gid, out var t))
            await DeleteAsync(t);
    }

    private void OpenCreate()
    {
        _editId = null;
        _formError = null;
        _formAccount = _accounts.FirstOrDefault()?.Id.ToString() ?? "";
        _formBooking = DateOnly.FromDateTime(DateTime.Today);
        _formValue = null;
        _formAmount = 0;
        _formCurrency = "CZK";
        _formCounterparty = "";
        _formCounterpartyAccount = "";
        _formVs = "";
        _formCs = "";
        _formSs = "";
        _formDescription = "";
        _formNote = "";
        _formCategory = "";
        _showEditor = true;
    }

    private void OpenEdit(TransactionDto t)
    {
        _editId = t.Id;
        _formError = null;
        _formAccount = t.BankAccountId.ToString();
        _formBooking = t.BookingDate;
        _formValue = t.ValueDate;
        _formAmount = t.Amount;
        _formCurrency = t.Currency;
        _formCounterparty = t.CounterpartyName ?? "";
        _formCounterpartyAccount = t.CounterpartyAccount ?? "";
        _formVs = t.VariableSymbol ?? "";
        _formCs = t.ConstantSymbol ?? "";
        _formSs = t.SpecificSymbol ?? "";
        _formDescription = t.Description ?? "";
        _formNote = t.Note ?? "";
        _formCategory = t.CategoryId?.ToString() ?? "";
        _showEditor = true;
    }

    private async Task SaveAsync()
    {
        _formError = null;
        if (_formAmount == 0)
        {
            _formError = "Částka nesmí být nulová.";
            return;
        }

        var fields = new TransactionFields
        {
            BookingDate = _formBooking,
            ValueDate = _formValue,
            Amount = _formAmount,
            Currency = string.IsNullOrWhiteSpace(_formCurrency) ? "CZK" : _formCurrency,
            CounterpartyName = _formCounterparty,
            CounterpartyAccount = _formCounterpartyAccount,
            VariableSymbol = _formVs,
            ConstantSymbol = _formCs,
            SpecificSymbol = _formSs,
            Description = _formDescription,
            Note = _formNote,
            CategoryId = Guid.TryParse(_formCategory, out var cid) ? cid : null,
        };

        var isEdit = _editId is not null;
        _saving = true;
        try
        {
            if (_editId is { } id)
            {
                var updated = await Api.UpdateTransactionAsync(id, new UpdateTransactionRequest { Fields = fields });
                if (updated is null)
                {
                    _formError = "Pohyb se nepodařilo uložit.";
                    return;
                }
            }
            else
            {
                if (!Guid.TryParse(_formAccount, out var accountId))
                {
                    _formError = "Vyberte účet.";
                    return;
                }
                var created = await Api.CreateTransactionAsync(new CreateTransactionRequest { BankAccountId = accountId, Fields = fields });
                if (created is null)
                {
                    _formError = "Pohyb se nepodařilo vytvořit.";
                    return;
                }
            }
            _showEditor = false;
            Toasts.ShowSuccess(isEdit ? "Změny byly uloženy." : "Pohyb byl vytvořen.");
            await LoadAsync();
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DeleteAsync(TransactionDto t)
    {
        var label = string.IsNullOrWhiteSpace(t.CounterpartyName) ? Money(t.Amount) : t.CounterpartyName!;
        var dialog = await Dialogs.ShowConfirmationAsync(
            $"Opravdu smazat tento pohyb: {label}? Tuto akci nelze vrátit zpět.",
            "Smazat", "Zrušit", "Smazání pohybu");
        var result = await dialog.Result;
        if (result.Cancelled)
            return;

        if (await Api.DeleteTransactionAsync(t.Id))
        {
            Toasts.ShowSuccess("Pohyb byl smazán.");
            await LoadAsync();
        }
        else
        {
            Toasts.ShowError("Pohyb se nepodařilo smazat.");
        }
    }

    private string CategoryColor(Guid? categoryId) =>
        categoryId is { } id && _categoryColors.TryGetValue(id, out var color) ? color : "#64748b";

    private static string Money(decimal value) =>
        value.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("cs-CZ")) + " Kč";

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("flowlioGrid.destroy", "tx-grid");
        }
        catch (JSDisconnectedException) { /* circuit/teardown */ }
        _gridRef?.Dispose();
    }
}
