@page "/transactions"
@attribute [Authorize]
@implements IAsyncDisposable
@inject FlowlioApi Api
@inject CurrentUserState CurrentUser
@inject IDialogService Dialogs
@inject IToastService Toasts
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Transakce – Flowlio</PageTitle>

<h1 class="page-title">Transakce</h1>

@if (!_canView)
{
    <FluentCard Class="panel">
        <FluentMessageBar Intent="MessageIntent.Warning">Nemáte oprávnění zobrazit finance této rodiny.</FluentMessageBar>
    </FluentCard>
}
else
{
<div class="toolbar">
    <FluentSearch @bind-Value="_search" @bind-Value:after="SearchChangedAsync"
                  Immediate="true" ImmediateDelay="300"
                  Placeholder="Fulltext: protistrana, popis, poznámka, VS…" Class="toolbar-search" />

    @if (_canManage && _accounts.Count > 0)
    {
        <div class="toolbar-actions">
            <FluentButton Appearance="Appearance.Neutral" OnClick="OpenCreate">+ Přidat pohyb</FluentButton>
        </div>
    }
</div>

<div class="toolbar">
    <FluentSelect TOption="string" @bind-Value="_accountValue" @bind-Value:after="FilterChangedAsync" Label="Účet">
        <FluentOption TOption="string" Value="">Všechny účty</FluentOption>
        @foreach (var a in _accounts)
        {
            <FluentOption TOption="string" Value="@a.Id.ToString()">@a.Name</FluentOption>
        }
    </FluentSelect>

    <FluentSelect TOption="string" @bind-Value="_categoryValue" @bind-Value:after="FilterChangedAsync" Label="Kategorie">
        <FluentOption TOption="string" Value="">Všechny kategorie</FluentOption>
        @foreach (var c in _categories)
        {
            <FluentOption TOption="string" Value="@c.Id.ToString()">@c.Name</FluentOption>
        }
    </FluentSelect>

    <FluentSelect TOption="string" @bind-Value="_typeValue" @bind-Value:after="FilterChangedAsync" Label="Typ">
        <FluentOption TOption="string" Value="">Vše</FluentOption>
        <FluentOption TOption="string" Value="@(((int)TransactionDirection.Incoming).ToString())">Příjmy</FluentOption>
        <FluentOption TOption="string" Value="@(((int)TransactionDirection.Outgoing).ToString())">Výdaje</FluentOption>
    </FluentSelect>

    <FluentSelect TOption="string" @bind-Value="_periodValue" @bind-Value:after="OnPeriodChangedAsync" Label="Období">
        <FluentOption TOption="string" Value="">Celé období</FluentOption>
        <FluentOption TOption="string" Value="thisMonth">Tento měsíc</FluentOption>
        <FluentOption TOption="string" Value="lastMonth">Minulý měsíc</FluentOption>
        <FluentOption TOption="string" Value="last30">Posledních 30 dní</FluentOption>
        <FluentOption TOption="string" Value="thisYear">Tento rok</FluentOption>
        @if (_periodValue == "custom")
        {
            <FluentOption TOption="string" Value="custom">Vlastní</FluentOption>
        }
    </FluentSelect>

    <div class="filter-range">
        <span class="filter-label">Od</span>
        <FluentDatePicker @bind-Value="_dateFrom" @bind-Value:after="OnDateEditedAsync" Culture="Cz" />
        <span class="filter-label">Do</span>
        <FluentDatePicker @bind-Value="_dateTo" @bind-Value:after="OnDateEditedAsync" Culture="Cz" />
    </div>
</div>

@if (_showEditor)
{
    <TransactionEditor @key="_editorKey" Accounts="_accounts" Categories="_categories"
                       Editing="_editingTx" OnSaved="EditorSavedAsync" OnCancel="@(() => _showEditor = false)" />
}

@if (_undoIds.Count > 0)
{
    <div class="undo-bar">
        <span>Smazáno @_undoIds.Count pohybů.</span>
        <div class="toolbar-actions">
            <FluentButton Appearance="Appearance.Accent" OnClick="UndoDeleteAsync">Vrátit zpět</FluentButton>
            <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => _undoIds = [])">Zavřít</FluentButton>
        </div>
    </div>
}

@if (_loading)
{
    <FluentProgressRing />
}
else if (_loadError)
{
    <FluentCard Class="panel">
        <div class="empty-state">
            <div class="empty-state-icon">⚠️</div>
            <p>Načtení transakcí se nezdařilo.</p>
            <FluentButton Appearance="Appearance.Accent" OnClick="@(() => LoadAsync())">Zkusit znovu</FluentButton>
        </div>
    </FluentCard>
}
else if (_rows.Count == 0)
{
    <FluentCard Class="panel">
        <div class="empty-state">
            <div class="empty-state-icon">🗒️</div>
            <p>Žádné transakce k zobrazení.</p>
            <p class="hint">Naimportujte výpis nebo přidejte pohyb ručně.</p>
            @if (_canManage && _accounts.Count > 0)
            {
                <FluentButton Appearance="Appearance.Accent" OnClick="OpenCreate">+ Přidat pohyb</FluentButton>
            }
        </div>
    </FluentCard>
}
else
{
    <div class="toolbar">
        <FluentSelect TOption="string" @bind-Value="_groupValue" @bind-Value:after="GroupChangedAsync" Label="Seskupit">
            <FluentOption TOption="string" Value="">Bez seskupení</FluentOption>
            <FluentOption TOption="string" Value="category">Podle kategorie</FluentOption>
            <FluentOption TOption="string" Value="month">Podle měsíce</FluentOption>
        </FluentSelect>
        <div class="toolbar-actions">
            @if (HasActiveFilters)
            {
                <FluentButton Appearance="Appearance.Stealth" OnClick="ClearFiltersAsync">Zrušit filtry</FluentButton>
            }
            <FluentButton Appearance="Appearance.Stealth" OnClick="ExportCsvAsync">Export CSV</FluentButton>
        </div>
    </div>
    @if (_canManage && _selectedIds.Count > 0)
    {
        <div class="bulk-bar">
            <span class="bulk-count">Vybráno @_selectedIds.Count pohybů</span>
            <FluentSelect TOption="string" @bind-Value="_bulkCategory" @bind-Value:after="BulkSetCategoryAsync">
                <FluentOption TOption="string" Value="">Přeřadit do kategorie…</FluentOption>
                @foreach (var c in _categories)
                {
                    <FluentOption TOption="string" Value="@c.Id.ToString()">@c.Name</FluentOption>
                }
            </FluentSelect>
            <div class="toolbar-actions">
                <FluentButton Appearance="Appearance.Stealth" OnClick="BulkDeleteAsync">Smazat vybrané</FluentButton>
                <FluentButton Appearance="Appearance.Stealth" OnClick="ClearSelectionAsync">Zrušit výběr</FluentButton>
            </div>
        </div>
    }
    <div class="summary-bar">
        <span class="summary-item"><span class="summary-label">Příjmy</span><span class="summary-value income">@Formatting.Money(_sumIncome)</span></span>
        <span class="summary-item"><span class="summary-label">Výdaje</span><span class="summary-value expense">@Formatting.Money(_sumExpense)</span></span>
        <span class="summary-item"><span class="summary-label">Bilance</span><span class="summary-value @(_sumNet >= 0 ? "income" : "expense")">@Formatting.Money(_sumNet)</span></span>
        <span class="summary-item summary-count"><span class="summary-label">Pohybů</span><span class="summary-value">@_sumCount</span></span>
    </div>
    <FluentCard Class="panel no-pad">
        <div id="tx-grid"></div>
    </FluentCard>
}

@if (_detailTx is { } d)
{
    <TransactionDetail Transaction="d" AccountNames="_accountNames" CategoryColors="_categoryColors"
                       CanManage="_canManage" OnEdit="DetailEdit" OnClose="@(() => _detailTx = null)" />
}
}

@code {
    private List<TransactionDto> _rows = [];
    private Dictionary<Guid, TransactionDto> _byId = [];
    private IReadOnlyList<BankAccountDto> _accounts = [];
    private IReadOnlyList<CategoryDto> _categories = [];
    private Dictionary<Guid, string> _categoryColors = [];
    private Dictionary<Guid, string> _accountNames = [];
    private TransactionDto? _detailTx;
    private bool _canView;
    private List<Guid> _selectedIds = [];
    private List<Guid> _undoIds = [];
    private string _bulkCategory = "";
    private bool _canManage;
    private bool _loading = true;
    private bool _loadError;
    private int _loadSeq;

    // Summary over the currently filtered rows (pushed from Tabulator via UpdateSummary).
    private int _sumCount;
    private decimal _sumIncome;
    private decimal _sumExpense;
    private decimal _sumNet;

    // Grid (Tabulator) state
    private DotNetObjectReference<Transactions>? _gridRef;
    private bool _renderPending;
    private string _groupValue = "";

    private static readonly System.Globalization.CultureInfo Cz = new("cs-CZ");

    // Filters (applied client-side via Tabulator)
    private string _search = "";
    private string _accountValue = "";
    private string _categoryValue = "";
    private string _typeValue = "";
    private string _periodValue = "";
    private DateTime? _dateFrom;
    private DateTime? _dateTo;

    // Create/edit editor (the form itself lives in <TransactionEditor>).
    private bool _showEditor;
    private TransactionDto? _editingTx;
    private int _editorKey;

    protected override async Task OnInitializedAsync()
    {
        _canView = await CurrentUser.CanAsync(Permission.ViewFinances);
        if (!_canView)
            return;

        _canManage = await CurrentUser.CanAsync(Permission.ManageTransactions);
        _accounts = await Api.GetAccountsAsync();
        _categories = await Api.GetCategoriesAsync();
        _categoryColors = _categories.ToDictionary(c => c.Id, c => c.Color);
        _accountNames = _accounts.ToDictionary(a => a.Id, a => a.Name);
        ReadUrl();
        await LoadAsync();
    }

    // --- URL state (shareable / survives refresh) ---------------------------
    private void ReadUrl()
    {
        var query = new Uri(Navigation.Uri).Query.TrimStart('?');
        var qp = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        foreach (var pair in query.Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var kv = pair.Split('=', 2);
            qp[Uri.UnescapeDataString(kv[0])] = kv.Length > 1 ? Uri.UnescapeDataString(kv[1]) : "";
        }
        string Get(string k) => qp.GetValueOrDefault(k, "");

        _search = Get("q");
        _accountValue = Get("ucet");
        _categoryValue = Get("kat");
        _typeValue = Get("typ");
        _groupValue = Get("sesk");
        if (DateTime.TryParse(Get("od"), out var od)) _dateFrom = od;
        if (DateTime.TryParse(Get("do"), out var dt)) _dateTo = dt;
        if (_dateFrom is not null || _dateTo is not null) _periodValue = "custom";
    }

    private void SyncUrl()
    {
        var q = new Dictionary<string, object?>
        {
            ["q"] = string.IsNullOrEmpty(_search) ? null : _search,
            ["ucet"] = string.IsNullOrEmpty(_accountValue) ? null : _accountValue,
            ["kat"] = string.IsNullOrEmpty(_categoryValue) ? null : _categoryValue,
            ["typ"] = string.IsNullOrEmpty(_typeValue) ? null : _typeValue,
            ["od"] = _dateFrom?.ToString("yyyy-MM-dd"),
            ["do"] = _dateTo?.ToString("yyyy-MM-dd"),
            ["sesk"] = string.IsNullOrEmpty(_groupValue) ? null : _groupValue,
        };
        Navigation.NavigateTo(Navigation.GetUriWithQueryParameters(q), replace: true);
    }

    // Structured-filter change from a select: sync the URL and re-apply client-side.
    private Task FilterChangedAsync()
    {
        SyncUrl();
        return ApplyClientFiltersAsync();
    }

    // Loads the matching transaction set from the server. The text search is a real PostgreSQL
    // full-text query (diacritics-insensitive, ranked); the structured filters below stay
    // client-side in Tabulator for instant feedback. The server caps pageSize at 200, so we page
    // through to load the whole matching set for client-side pagination/grouping/footer sums.
    private async Task LoadAsync(bool keepUndo = false)
    {
        if (!keepUndo)
            _undoIds = [];
        // Each load takes a sequence number; a slower earlier request that finishes after a newer
        // one (e.g. while typing in search) is discarded instead of clobbering fresher results.
        var seq = ++_loadSeq;
        _loading = true;
        _loadError = false;
        StateHasChanged();

        var all = new List<TransactionDto>();
        var failed = false;
        const int size = 200;
        for (var page = 1; page <= 200; page++)
        {
            var result = await Api.GetTransactionsAsync(search: _search, page: page, pageSize: size);
            if (result is null)
            {
                failed = true; // null means a non-success response, not an empty page
                break;
            }
            if (result.Items.Count == 0)
                break;
            all.AddRange(result.Items);
            if (all.Count >= result.TotalCount)
                break;
        }

        if (seq != _loadSeq)
            return; // superseded by a newer load — drop these stale results

        if (failed)
        {
            _loadError = true;
            _loading = false;
            Toasts.ShowError("Načtení transakcí se nezdařilo.");
            StateHasChanged();
            return;
        }

        _rows = all;
        _byId = all.ToDictionary(t => t.Id);
        _loading = false;
        _renderPending = true;
        StateHasChanged();
    }

    // The search term runs server-side (FTS), so changing it reloads from the server.
    private Task SearchChangedAsync()
    {
        SyncUrl();
        return LoadAsync();
    }

    private bool HasActiveFilters =>
        !string.IsNullOrEmpty(_search) || _accountValue != "" || _categoryValue != ""
        || _typeValue != "" || _dateFrom is not null || _dateTo is not null;

    // Pushes the structured filters into Tabulator — no server round-trip, and the footer sum /
    // pagination follow the filtered set instantly. (Text search is handled server-side in LoadAsync.)
    private async Task ApplyClientFiltersAsync()
    {
        var type = _typeValue == ((int)TransactionDirection.Incoming).ToString() ? "in"
            : _typeValue == ((int)TransactionDirection.Outgoing).ToString() ? "out" : "";

        await JS.InvokeVoidAsync("flowlioGrid.setFilters", "tx-grid", new
        {
            accountId = _accountValue,
            categoryId = _categoryValue,
            type,
            dateFrom = _dateFrom is { } f ? f.ToString("yyyy-MM-dd") : "",
            dateTo = _dateTo is { } t ? t.ToString("yyyy-MM-dd") : "",
        });
    }

    private Task OnDateEditedAsync()
    {
        _periodValue = _dateFrom is null && _dateTo is null ? "" : "custom";
        SyncUrl();
        return ApplyClientFiltersAsync();
    }

    private Task OnPeriodChangedAsync()
    {
        var today = DateTime.Today;
        switch (_periodValue)
        {
            case "thisMonth":
                _dateFrom = new DateTime(today.Year, today.Month, 1);
                _dateTo = _dateFrom.Value.AddMonths(1).AddDays(-1);
                break;
            case "lastMonth":
                var lm = new DateTime(today.Year, today.Month, 1).AddMonths(-1);
                _dateFrom = lm;
                _dateTo = lm.AddMonths(1).AddDays(-1);
                break;
            case "last30":
                _dateFrom = today.AddDays(-30);
                _dateTo = today;
                break;
            case "thisYear":
                _dateFrom = new DateTime(today.Year, 1, 1);
                _dateTo = new DateTime(today.Year, 12, 31);
                break;
            default: // "" (celé období) or "custom"
                if (_periodValue != "custom")
                {
                    _dateFrom = null;
                    _dateTo = null;
                }
                break;
        }
        SyncUrl();
        return ApplyClientFiltersAsync();
    }

    private async Task ClearFiltersAsync()
    {
        var hadSearch = !string.IsNullOrEmpty(_search);
        _search = "";
        _accountValue = "";
        _categoryValue = "";
        _typeValue = "";
        _periodValue = "";
        _dateFrom = null;
        _dateTo = null;
        SyncUrl();

        if (hadSearch)
            await LoadAsync(); // reloads the unfiltered set and re-applies (now empty) client filters
        else
            await ApplyClientFiltersAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            _gridRef ??= DotNetObjectReference.Create(this);

        if (_renderPending && !_loading)
        {
            _renderPending = false;
            if (_rows.Count > 0)
                await RenderGridAsync();
            else
                await JS.InvokeVoidAsync("flowlioGrid.destroy", "tx-grid");
        }
    }

    private async Task RenderGridAsync()
    {
        var data = _rows.Select(t => new
        {
            id = t.Id.ToString(),
            accountId = t.BankAccountId.ToString(),
            accountName = _accountNames.GetValueOrDefault(t.BankAccountId, ""),
            categoryId = t.CategoryId?.ToString() ?? "",
            bookingDate = t.BookingDate.ToString("yyyy-MM-dd"),
            counterparty = t.CounterpartyName ?? "",
            categoryName = t.CategoryName ?? "",
            categoryColor = CategoryColor(t.CategoryId),
            description = t.Description ?? "",
            vs = t.VariableSymbol ?? "",
            amount = (double)t.Amount,
        });

        var categories = _categories.Select(c => new { id = c.Id.ToString(), name = c.Name, color = c.Color });

        await JS.InvokeVoidAsync("flowlioGrid.render", "tx-grid", data,
            new { canManage = _canManage, groupBy = _groupValue, pageSize = 50, search = _search ?? "", categories }, _gridRef);

        // Re-applies any active filters after a (re)render, e.g. after save/delete.
        if (HasActiveFilters)
            await ApplyClientFiltersAsync();
    }

    private async Task GroupChangedAsync()
    {
        SyncUrl();
        await JS.InvokeVoidAsync("flowlioGrid.setGroup", "tx-grid", _groupValue);
    }

    private async Task ExportCsvAsync() =>
        await JS.InvokeVoidAsync("flowlioGrid.exportCsv", "tx-grid");

    [JSInvokable]
    public void GridEdit(string id)
    {
        if (Guid.TryParse(id, out var gid) && _byId.TryGetValue(gid, out var t))
        {
            OpenEdit(t);
            StateHasChanged();
        }
    }

    [JSInvokable]
    public async Task GridDelete(string id)
    {
        if (Guid.TryParse(id, out var gid) && _byId.TryGetValue(gid, out var t))
            await DeleteAsync(t);
    }

    [JSInvokable]
    public void GridRowClick(string id)
    {
        if (Guid.TryParse(id, out var gid) && _byId.TryGetValue(gid, out var t))
        {
            _detailTx = t;
            StateHasChanged();
        }
    }

    // All editable fields of a transaction, used to re-save it with one field changed.
    private static TransactionFields FieldsFrom(TransactionDto t) => new()
    {
        BookingDate = t.BookingDate,
        ValueDate = t.ValueDate,
        Amount = t.Amount,
        Currency = t.Currency,
        CounterpartyName = t.CounterpartyName,
        CounterpartyAccount = t.CounterpartyAccount,
        VariableSymbol = t.VariableSymbol,
        ConstantSymbol = t.ConstantSymbol,
        SpecificSymbol = t.SpecificSymbol,
        Description = t.Description,
        Note = t.Note,
        CategoryId = t.CategoryId,
    };

    // Inline re-categorisation from the grid: persist the new category and reload.
    [JSInvokable]
    public async Task GridSetCategory(string id, string categoryId)
    {
        if (!Guid.TryParse(id, out var gid) || !_byId.TryGetValue(gid, out var t))
            return;
        Guid? newCat = Guid.TryParse(categoryId, out var c) ? c : null;
        if (newCat == t.CategoryId)
            return;

        var updated = await Api.UpdateTransactionAsync(gid,
            new UpdateTransactionRequest { Fields = FieldsFrom(t) with { CategoryId = newCat }, Version = t.Version });
        if (updated is not null)
            Toasts.ShowSuccess("Kategorie změněna.");
        else
            Toasts.ShowError("Změnu kategorie se nepodařilo uložit.");
        await LoadAsync();
    }

    [JSInvokable]
    public void GridSelectionChanged(string[] ids)
    {
        _selectedIds = ids
            .Select(s => Guid.TryParse(s, out var g) ? g : Guid.Empty)
            .Where(g => g != Guid.Empty)
            .ToList();
        StateHasChanged();
    }

    private async Task BulkDeleteAsync()
    {
        if (_selectedIds.Count == 0)
            return;
        var dialog = await Dialogs.ShowConfirmationAsync(
            $"Opravdu smazat {_selectedIds.Count} vybraných pohybů?",
            "Smazat", "Zrušit", "Hromadné smazání");
        if ((await dialog.Result).Cancelled)
            return;

        var ids = _selectedIds.ToList();
        var count = await Api.BulkDeleteTransactionsAsync(ids);
        if (count > 0)
        {
            _undoIds = ids;
            Toasts.ShowSuccess($"Smazáno {count} pohybů.");
        }
        else
        {
            Toasts.ShowError("Pohyby se nepodařilo smazat.");
        }
        _selectedIds = [];
        await LoadAsync(keepUndo: true);
    }

    private async Task BulkSetCategoryAsync()
    {
        if (_selectedIds.Count == 0 || string.IsNullOrEmpty(_bulkCategory))
            return;
        Guid? newCat = Guid.TryParse(_bulkCategory, out var c) ? c : null;

        var count = await Api.BulkCategorizeAsync(_selectedIds.ToList(), newCat);
        Toasts.ShowSuccess($"Kategorie nastavena u {count} pohybů.");
        _bulkCategory = "";
        _selectedIds = [];
        await LoadAsync();
    }

    private async Task ClearSelectionAsync()
    {
        _selectedIds = [];
        _bulkCategory = "";
        await JS.InvokeVoidAsync("flowlioGrid.clearSelection", "tx-grid");
    }

    // Pushed by the grid whenever the filtered set changes; drives the summary bar.
    [JSInvokable]
    public void UpdateSummary(int count, double income, double expense, double net)
    {
        _sumCount = count;
        _sumIncome = (decimal)income;
        _sumExpense = (decimal)expense;
        _sumNet = (decimal)net;
        StateHasChanged();
    }

    // Open the editor for a new movement (null) or an existing one. A fresh @key per open makes
    // <TransactionEditor> re-initialise its form even if the editor is already showing.
    private void OpenEditor(TransactionDto? t)
    {
        _editingTx = t;
        _editorKey++;
        _showEditor = true;
    }

    private void OpenCreate() => OpenEditor(null);
    private void OpenEdit(TransactionDto t) => OpenEditor(t);

    private async Task EditorSavedAsync()
    {
        _showEditor = false;
        await LoadAsync();
    }

    private void DetailEdit(TransactionDto t)
    {
        _detailTx = null;
        OpenEditor(t);
    }

    private async Task DeleteAsync(TransactionDto t)
    {
        var label = string.IsNullOrWhiteSpace(t.CounterpartyName) ? Formatting.Money(t.Amount) : t.CounterpartyName!;
        var dialog = await Dialogs.ShowConfirmationAsync(
            $"Opravdu smazat tento pohyb: {label}?",
            "Smazat", "Zrušit", "Smazání pohybu");
        var result = await dialog.Result;
        if (result.Cancelled)
            return;

        if (await Api.DeleteTransactionAsync(t.Id))
        {
            _undoIds = [t.Id];
            Toasts.ShowSuccess("Pohyb byl smazán.");
            await LoadAsync(keepUndo: true);
        }
        else
        {
            Toasts.ShowError("Pohyb se nepodařilo smazat.");
        }
    }

    private async Task UndoDeleteAsync()
    {
        if (_undoIds.Count == 0)
            return;
        var count = await Api.RestoreTransactionsAsync(_undoIds);
        Toasts.ShowSuccess($"Obnoveno {count} pohybů.");
        _undoIds = [];
        await LoadAsync();
    }

    private string CategoryColor(Guid? categoryId) =>
        categoryId is { } id && _categoryColors.TryGetValue(id, out var color) ? color : "#64748b";

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("flowlioGrid.destroy", "tx-grid");
        }
        catch (JSDisconnectedException) { /* circuit/teardown */ }
        _gridRef?.Dispose();
    }
}
