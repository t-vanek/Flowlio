@page "/rules"
@attribute [Authorize]
@using System.Globalization
@using System.Text
@using System.Text.Json
@inject FlowlioApi Api
@inject CurrentUserState CurrentUser
@inject IDialogService Dialogs
@inject IToastService Toasts
@inject IJSRuntime JS

<PageTitle>Pravidla kategorizace – Flowlio</PageTitle>

<h1 class="page-title">Pravidla kategorizace</h1>

@if (!_canManage)
{
    <FluentCard Class="panel">
        <FluentMessageBar Intent="MessageIntent.Warning">Nemáte oprávnění spravovat pravidla kategorizace.</FluentMessageBar>
    </FluentCard>
}
else
{
@if (_suggestions.Count > 0)
{
    <FluentCard Class="panel">
        <h2 class="panel-title">Navrhovaná pravidla</h2>
        <p class="muted">
            Tyto obchodníky jste opakovaně zařadili ručně. Flowlio z nich umí vytvořit pravidlo,
            aby se příště zařadily samy. Potvrďte, nebo skryjte.
        </p>
        @foreach (var s in _suggestions)
        {
            <div class="account-row">
                <div>
                    <div class="account-name">„@s.Pattern"</div>
                    <div class="muted">→ @s.CategoryName · ručně zařazeno @s.MatchCount×</div>
                </div>
                <div>
                    <FluentButton Appearance="Appearance.Accent" OnClick="@(() => AcceptSuggestionAsync(s))">Vytvořit pravidlo</FluentButton>
                    <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => DismissSuggestion(s))">Skrýt</FluentButton>
                </div>
            </div>
        }
    </FluentCard>
}
<div class="panel-grid">
    <FluentCard Class="panel">
        <h2 class="panel-title">@(_editingId is null ? "Nové pravidlo" : "Upravit pravidlo")</h2>
        <p class="muted">
            Transakci dostane kategorii, když zvolené pole odpovídá zadanému vzoru (nezáleží na velikosti
            písmen ani diakritice). „Kdekoliv" hledá ve všech textových polích – vhodné pro platby kartou,
            kde obchodník bývá jen v popisu. Způsob shody: „Část textu" hledá vzor kdekoliv, „Celé slovo"
            jen jako samostatné slovo (vhodné pro krátké vzory jako „Plat"), „Regulární výraz" pro pokročilé.
            Příjmová pravidla se uplatní jen na příjmy, výdajová jen na výdaje.
        </p>
        <EditForm Model="_model" OnValidSubmit="SaveAsync">
            <DataAnnotationsValidator />
            <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
                <div>
                    <FluentTextField @bind-Value="_model.Pattern" Label="Vzor (hledaný text, volitelné)" Style="width:100%" Placeholder="Albert" />
                    <FluentValidationMessage For="@(() => _model.Pattern)" />
                </div>
                <FluentSelect TOption="string" @bind-Value="_fieldValue" Label="Pole" Style="width:100%">
                    @foreach (var f in Enum.GetValues<RuleMatchField>())
                    {
                        <FluentOption TOption="string" Value="@(((int)f).ToString())">@FieldLabel(f)</FluentOption>
                    }
                </FluentSelect>
                <FluentSelect TOption="string" @bind-Value="_modeValue" Label="Způsob shody" Style="width:100%">
                    @foreach (var m in Enum.GetValues<RuleMatchMode>())
                    {
                        <FluentOption TOption="string" Value="@(((int)m).ToString())">@ModeLabel(m)</FluentOption>
                    }
                </FluentSelect>
                <FluentSelect TOption="string" @bind-Value="_categoryValue" Label="Kategorie" Style="width:100%">
                    @foreach (var c in _categories ?? [])
                    {
                        <FluentOption TOption="string" Value="@c.Id.ToString()">@c.Name (@KindLabel(c.Kind))</FluentOption>
                    }
                </FluentSelect>
                <FluentSelect TOption="string" @bind-Value="_ruleScopeValue" Label="Rozsah" Style="width:100%">
                    <FluentOption TOption="string" Value="@(((int)RuleScope.Personal).ToString())">Osobní (mé účty)</FluentOption>
                    @if (_isOwner)
                    {
                        <FluentOption TOption="string" Value="@(((int)RuleScope.Account).ToString())">Konkrétní účet</FluentOption>
                        <FluentOption TOption="string" Value="@(((int)RuleScope.Family).ToString())">Celá rodina (globálně)</FluentOption>
                    }
                </FluentSelect>
                @if (_ruleScopeValue == ((int)RuleScope.Account).ToString())
                {
                    <FluentSelect TOption="string" @bind-Value="_accountValue" @bind-Value:after="OnRuleAccountChanged" Label="Účet" Style="width:100%">
                        <FluentOption TOption="string" Value="">— vyberte účet —</FluentOption>
                        @foreach (var a in _accounts ?? [])
                        {
                            <FluentOption TOption="string" Value="@a.Id.ToString()">@a.Name</FluentOption>
                        }
                    </FluentSelect>
                }
                <div>
                    <label class="field-label">Podmínka na částku (volitelné)</label>
                    <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" VerticalAlignment="VerticalAlignment.Bottom">
                        <FluentTextField @bind-Value="_minAmount" Label="Od" Style="width:120px" Placeholder="0" />
                        <FluentTextField @bind-Value="_maxAmount" Label="Do" Style="width:120px" Placeholder="∞" />
                        <FluentTextField @bind-Value="_amountCurrency" Label="Měna" Style="width:90px" Maxlength="3" />
                    </FluentStack>
                    <span class="muted">Porovnává se velikost částky (kladně). Vyplňte vzor a/nebo částku.</span>
                </div>
                <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" VerticalAlignment="VerticalAlignment.Bottom">
                    <FluentNumberField @bind-Value="_model.Priority" Label="Priorita (vyšší vyhrává)" Style="width:160px" />
                    <FluentSelect TOption="string" @bind-Value="_activeValue" Label="Aktivní" Style="width:120px">
                        <FluentOption TOption="string" Value="true">Ano</FluentOption>
                        <FluentOption TOption="string" Value="false">Ne</FluentOption>
                    </FluentSelect>
                </FluentStack>
                <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8">
                    <FluentButton Type="ButtonType.Submit" Appearance="Appearance.Accent" Loading="_busy" Disabled="@(_categories is null or { Count: 0 })">
                        @(_editingId is null ? "Přidat pravidlo" : "Uložit změny")
                    </FluentButton>
                    <FluentButton Appearance="Appearance.Stealth" OnClick="PreviewAsync" Loading="_previewing">Náhled dopadu</FluentButton>
                    @if (_editingId is not null)
                    {
                        <FluentButton Appearance="Appearance.Stealth" OnClick="CancelEdit">Zrušit úpravu</FluentButton>
                    }
                </FluentStack>
                @if (_preview is { } p)
                {
                    <FluentMessageBar Intent="@(p.Matches == 0 ? MessageIntent.Warning : MessageIntent.Info)">
                        Sedne na <strong>@p.Matches</strong> pohybů@(p.WouldRecategorize > 0 ? $" (z toho {p.WouldRecategorize} už zařazených by se přeřadilo)" : "").
                        @if (p.Samples.Count > 0)
                        {
                            <ul class="muted" style="margin:4px 0 0">
                                @foreach (var s in p.Samples)
                                {
                                    <li>@Formatting.Date(s.BookingDate) · @(string.IsNullOrWhiteSpace(s.Counterparty) ? "—" : s.Counterparty) · @Formatting.Money(s.Amount, s.Currency) · @(s.CurrentCategoryName ?? "bez kategorie")</li>
                                }
                            </ul>
                        }
                    </FluentMessageBar>
                }
                @if (_categories is { Count: 0 })
                {
                    <FluentMessageBar Intent="MessageIntent.Info">Nejprve vytvořte alespoň jednu kategorii.</FluentMessageBar>
                }
            </FluentStack>
        </EditForm>
    </FluentCard>

    <FluentCard Class="panel">
        <div class="account-row">
            <h2 class="panel-title">Pravidla</h2>
            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" VerticalAlignment="VerticalAlignment.Bottom" Wrap="true">
                <FluentSelect TOption="string" @bind-Value="_scopeValue" Label="Rozsah přepočtu">
                    <FluentOption TOption="string" Value="true">Jen nezařazené</FluentOption>
                    <FluentOption TOption="string" Value="false">Všechny pohyby</FluentOption>
                </FluentSelect>
                <FluentButton Appearance="Appearance.Accent" OnClick="RecategorizeAsync" Loading="_recategorizing">
                    Přepočítat kategorie
                </FluentButton>
                <FluentButton Appearance="Appearance.Stealth" OnClick="ExportAsync" Title="Stáhnout pravidla jako JSON">Export</FluentButton>
                <label class="file-field" style="display:inline-flex;align-items:center;gap:6px" title="Importovat pravidla z JSON">
                    <span class="muted">Import:</span>
                    <InputFile OnChange="ImportAsync" accept=".json" />
                </label>
            </FluentStack>
        </div>

        @if (_rules is null)
        {
            <FluentProgressRing />
        }
        else if (_rules.Count == 0)
        {
            <p class="muted">Zatím žádná pravidla. Vytvořte první vlevo, nebo použijte „Vytvořit pravidlo" u konkrétní transakce.</p>
        }
        else
        {
            @foreach (var r in _rules)
            {
                <div class="account-row">
                    <div>
                        <div class="account-name">
                            @if (!string.IsNullOrWhiteSpace(r.Pattern))
                            {
                                <span>„@r.Pattern"</span>
                            }
                            else
                            {
                                <span>@(AmountLabel(r) ?? "pravidlo")</span>
                            }
                            @if (!r.IsActive)
                            {
                                <span class="muted">· neaktivní</span>
                            }
                        </div>
                        <div class="muted">
                            @ScopeLabel(r) · @FieldLabel(r.Field) · @ModeLabel(r.MatchMode)
                            @if (!string.IsNullOrWhiteSpace(r.Pattern) && AmountLabel(r) is { } amt)
                            {
                                <span> · @amt</span>
                            }
                            → @(r.CategoryName ?? "—") · priorita @r.Priority
                            @if (r.UsageCount > 0)
                            {
                                <span> · použito @r.UsageCount×</span>
                            }
                            else
                            {
                                <span> · <span style="color:var(--warning, #b45309)">zatím nic nezařadilo</span></span>
                            }
                        </div>
                    </div>
                    <div>
                        <FluentButton Appearance="Appearance.Stealth" Title="Nahoru" OnClick="@(() => MoveAsync(r, -1))">▲</FluentButton>
                        <FluentButton Appearance="Appearance.Stealth" Title="Dolů" OnClick="@(() => MoveAsync(r, 1))">▼</FluentButton>
                        <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => EditRule(r))">Upravit</FluentButton>
                        <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => ToggleActiveAsync(r))">
                            @(r.IsActive ? "Deaktivovat" : "Aktivovat")
                        </FluentButton>
                        <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => DeleteAsync(r))">Smazat</FluentButton>
                    </div>
                </div>
            }
        }
    </FluentCard>
</div>

@if (_deletedRules.Count > 0)
{
    <FluentCard Class="panel">
        <h2 class="panel-title">Smazaná pravidla</h2>
        <p class="muted">Smazaná pravidla už nezařazují, ale můžete je obnovit.</p>
        @foreach (var r in _deletedRules)
        {
            <div class="account-row">
                <div>
                    <div class="account-name">„@r.Pattern"</div>
                    <div class="muted">
                        @FieldLabel(r.Field) · @ModeLabel(r.MatchMode) → @(r.CategoryName ?? "—")
                        @if (r.DeletedAt is { } d)
                        {
                            <span> · smazáno @Formatting.Date(d)</span>
                        }
                    </div>
                </div>
                <div>
                    <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => RestoreAsync(r))">Obnovit</FluentButton>
                </div>
            </div>
        }
    </FluentCard>
}
}

@code {
    private IReadOnlyList<CategorizationRuleDto>? _rules;
    private IReadOnlyList<CategorizationRuleDto> _deletedRules = [];
    private IReadOnlyList<CategoryDto>? _categories;
    private IReadOnlyList<BankAccountDto>? _accounts;
    private IReadOnlyList<RuleSuggestionDto> _suggestions = [];

    private CategorizationRuleRequest _model = new();
    private string _fieldValue = ((int)RuleMatchField.Any).ToString();
    private string _modeValue = ((int)RuleMatchMode.Substring).ToString();
    private string _ruleScopeValue = ((int)RuleScope.Personal).ToString();
    private string _accountValue = "";
    private string _minAmount = "";
    private string _maxAmount = "";
    private string _amountCurrency = "CZK";
    private string _categoryValue = "";
    private string _activeValue = "true";
    private Guid? _editingId;

    private string _scopeValue = "true"; // recategorize scope (uncategorized vs all)
    private RulePreviewDto? _preview;
    private bool _previewing;
    private bool _busy;
    private bool _recategorizing;
    private bool _canManage;
    private bool _isOwner;

    /// <summary>Pre-fills the create form from "Vytvořit pravidlo" on a transaction
    /// (/rules?pattern=...&amp;categoryId=...).</summary>
    [SupplyParameterFromQuery] public string? Pattern { get; set; }
    [SupplyParameterFromQuery] public Guid? CategoryId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var me = await CurrentUser.GetAsync();
        _canManage = me?.Can(Permission.ManageTransactions) ?? false;
        _isOwner = me?.Role == MemberRole.Owner;
        if (!_canManage)
            return;

        _categories = await Api.GetCategoriesAsync();
        _categoryValue = _categories.FirstOrDefault()?.Id.ToString() ?? "";
        _accounts = await Api.GetAccountsAsync();
        _amountCurrency = DefaultCurrency();

        if (!string.IsNullOrWhiteSpace(Pattern))
            _model.Pattern = Pattern!.Trim();
        // Prefill the category when arriving from a transaction's "Vytvořit pravidlo".
        if (CategoryId is { } cid && _categories.Any(c => c.Id == cid))
            _categoryValue = cid.ToString();

        await LoadRulesAsync();
    }

    private async Task LoadRulesAsync()
    {
        _rules = await Api.GetRulesAsync();
        _deletedRules = await Api.GetDeletedRulesAsync();
        _suggestions = await Api.GetRuleSuggestionsAsync();
    }

    private async Task MoveAsync(CategorizationRuleDto r, int delta)
    {
        if (_rules is null)
            return;
        var list = _rules.ToList();
        var i = list.FindIndex(x => x.Id == r.Id);
        var j = i + delta;
        if (i < 0 || j < 0 || j >= list.Count)
            return;
        (list[i], list[j]) = (list[j], list[i]);
        _rules = list;
        await Api.ReorderRulesAsync(list.Select(x => x.Id).ToList());
        await LoadRulesAsync();
    }

    private async Task ExportAsync()
    {
        var rules = await Api.ExportRulesAsync();
        if (rules.Count == 0)
        {
            Toasts.ShowError("Žádná pravidla k exportu.");
            return;
        }
        var json = JsonSerializer.Serialize(rules, new JsonSerializerOptions { WriteIndented = true });
        var base64 = Convert.ToBase64String(Encoding.UTF8.GetBytes(json));
        await JS.InvokeVoidAsync("flowlioDownload.fromBytes", "flowlio-pravidla.json", base64, "application/json");
    }

    private async Task ImportAsync(InputFileChangeEventArgs e)
    {
        try
        {
            await using var stream = e.File.OpenReadStream(2 * 1024 * 1024);
            var items = await JsonSerializer.DeserializeAsync<List<RuleExportDto>>(
                stream, new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            if (items is null || items.Count == 0)
            {
                Toasts.ShowError("Soubor neobsahuje žádná pravidla.");
                return;
            }
            var result = await Api.ImportRulesAsync(items);
            if (result is null)
            {
                Toasts.ShowError("Import se nezdařil.");
                return;
            }
            Toasts.ShowSuccess($"Importováno {result.Imported} pravidel, přeskočeno {result.Skipped}.");
            await LoadRulesAsync();
        }
        catch
        {
            Toasts.ShowError("Soubor se nepodařilo načíst (neplatný JSON).");
        }
    }

    private async Task RestoreAsync(CategorizationRuleDto r)
    {
        if (await Api.RestoreRuleAsync(r.Id))
            Toasts.ShowSuccess($"Pravidlo „{r.Pattern}“ bylo obnoveno.");
        else
            Toasts.ShowError("Pravidlo se nepodařilo obnovit.");
        await LoadRulesAsync();
    }

    private async Task AcceptSuggestionAsync(RuleSuggestionDto s)
    {
        var created = await Api.CreateRuleAsync(new CategorizationRuleRequest
        {
            Field = RuleMatchField.Any,
            MatchMode = RuleMatchMode.Substring,
            Pattern = s.Pattern,
            CategoryId = s.CategoryId,
            Priority = 0,
            IsActive = true,
        });
        if (created is null)
        {
            Toasts.ShowError("Pravidlo se nepodařilo vytvořit.");
            return;
        }
        Toasts.ShowSuccess($"Pravidlo „{s.Pattern}“ bylo vytvořeno.");
        await LoadRulesAsync();
    }

    private async Task DismissSuggestion(RuleSuggestionDto s)
    {
        if (await Api.DismissRuleSuggestionAsync(s.Pattern, s.CategoryId))
            _suggestions = _suggestions.Where(x => x != s).ToList();
        else
            Toasts.ShowError("Návrh se nepodařilo skrýt.");
    }

    /// <summary>Builds a rule request from the form, or null + a toast when the inputs are invalid.</summary>
    private CategorizationRuleRequest? BuildRequest()
    {
        if (!Guid.TryParse(_categoryValue, out var categoryId))
        {
            Toasts.ShowError("Vyberte kategorii.");
            return null;
        }

        var scope = (RuleScope)int.Parse(_ruleScopeValue);
        Guid? accountId = Guid.TryParse(_accountValue, out var aid) ? aid : null;
        if (scope == RuleScope.Account && accountId is null)
        {
            Toasts.ShowError("Pro pravidlo na konkrétní účet vyberte účet.");
            return null;
        }

        decimal? min = null, max = null;
        if (!string.IsNullOrWhiteSpace(_minAmount) && !TryParseAmount(_minAmount, out min))
        {
            Toasts.ShowError("Neplatná částka „od“.");
            return null;
        }
        if (!string.IsNullOrWhiteSpace(_maxAmount) && !TryParseAmount(_maxAmount, out max))
        {
            Toasts.ShowError("Neplatná částka „do“.");
            return null;
        }
        var hasAmount = min is not null || max is not null;
        if (string.IsNullOrWhiteSpace(_model.Pattern) && !hasAmount)
        {
            Toasts.ShowError("Zadejte vzor nebo podmínku na částku.");
            return null;
        }
        if (hasAmount && string.IsNullOrWhiteSpace(_amountCurrency))
        {
            Toasts.ShowError("U podmínky na částku zadejte měnu.");
            return null;
        }
        if (min is { } mn && max is { } mx && mn > mx)
        {
            Toasts.ShowError("Částka „od“ nesmí být větší než „do“.");
            return null;
        }

        return new CategorizationRuleRequest
        {
            Scope = scope,
            BankAccountId = scope == RuleScope.Account ? accountId : null,
            Field = (RuleMatchField)int.Parse(_fieldValue),
            MatchMode = (RuleMatchMode)int.Parse(_modeValue),
            Pattern = _model.Pattern,
            MinAmount = hasAmount ? min : null,
            MaxAmount = hasAmount ? max : null,
            AmountCurrency = hasAmount ? _amountCurrency.Trim().ToUpperInvariant() : null,
            CategoryId = categoryId,
            Priority = _model.Priority,
            IsActive = _activeValue == "true",
            Version = _model.Version,
        };
    }

    private async Task PreviewAsync()
    {
        if (BuildRequest() is not { } req)
            return;
        _previewing = true;
        try
        {
            _preview = await Api.PreviewRuleAsync(req);
            if (_preview is null)
                Toasts.ShowError("Náhled se nepodařilo spočítat.");
        }
        finally
        {
            _previewing = false;
        }
    }

    private async Task SaveAsync()
    {
        if (!Guid.TryParse(_categoryValue, out var categoryId))
        {
            Toasts.ShowError("Vyberte kategorii.");
            return;
        }

        var scope = (RuleScope)int.Parse(_ruleScopeValue);
        Guid? accountId = Guid.TryParse(_accountValue, out var aid) ? aid : null;
        if (scope == RuleScope.Account && accountId is null)
        {
            Toasts.ShowError("Pro pravidlo na konkrétní účet vyberte účet.");
            return;
        }

        decimal? min = null, max = null;
        if (!string.IsNullOrWhiteSpace(_minAmount) && !TryParseAmount(_minAmount, out min))
        {
            Toasts.ShowError("Neplatná částka „od“.");
            return;
        }
        if (!string.IsNullOrWhiteSpace(_maxAmount) && !TryParseAmount(_maxAmount, out max))
        {
            Toasts.ShowError("Neplatná částka „do“.");
            return;
        }
        var hasAmount = min is not null || max is not null;
        if (string.IsNullOrWhiteSpace(_model.Pattern) && !hasAmount)
        {
            Toasts.ShowError("Zadejte vzor nebo podmínku na částku.");
            return;
        }
        if (hasAmount && string.IsNullOrWhiteSpace(_amountCurrency))
        {
            Toasts.ShowError("U podmínky na částku zadejte měnu.");
            return;
        }
        if (min is { } mn && max is { } mx && mn > mx)
        {
            Toasts.ShowError("Částka „od“ nesmí být větší než „do“.");
            return;
        }

        _busy = true;
        try
        {
            _model.Field = (RuleMatchField)int.Parse(_fieldValue);
            _model.MatchMode = (RuleMatchMode)int.Parse(_modeValue);
            _model.Scope = scope;
            _model.BankAccountId = scope == RuleScope.Account ? accountId : null;
            _model.MinAmount = hasAmount ? min : null;
            _model.MaxAmount = hasAmount ? max : null;
            _model.AmountCurrency = hasAmount ? _amountCurrency.Trim().ToUpperInvariant() : null;
            _model.CategoryId = categoryId;
            _model.IsActive = _activeValue == "true";

            var saved = _editingId is { } id
                ? await Api.UpdateRuleAsync(id, _model)
                : await Api.CreateRuleAsync(_model);

            if (saved is null)
            {
                Toasts.ShowError(_editingId is null
                    ? "Pravidlo se nepodařilo uložit."
                    : "Pravidlo se nepodařilo uložit (mezitím ho možná změnil někdo jiný — zavřete a otevřete znovu).");
                return;
            }

            Toasts.ShowSuccess(_editingId is null ? "Pravidlo bylo vytvořeno a aplikováno na nezařazené pohyby." : "Pravidlo bylo uloženo.");
            ResetForm();
            await LoadRulesAsync();
        }
        finally
        {
            _busy = false;
        }
    }

    private void EditRule(CategorizationRuleDto r)
    {
        _editingId = r.Id;
        _model = new CategorizationRuleRequest { Pattern = r.Pattern, Priority = r.Priority, Version = r.Version };
        _fieldValue = ((int)r.Field).ToString();
        _modeValue = ((int)r.MatchMode).ToString();
        _ruleScopeValue = ((int)r.Scope).ToString();
        _accountValue = r.BankAccountId?.ToString() ?? "";
        _minAmount = r.MinAmount?.ToString("0.##", CultureInfo.InvariantCulture) ?? "";
        _maxAmount = r.MaxAmount?.ToString("0.##", CultureInfo.InvariantCulture) ?? "";
        _amountCurrency = r.AmountCurrency ?? DefaultCurrency();
        _categoryValue = r.CategoryId.ToString();
        _activeValue = r.IsActive ? "true" : "false";
    }

    private void CancelEdit() => ResetForm();

    private void ResetForm()
    {
        _editingId = null;
        _preview = null;
        _model = new CategorizationRuleRequest();
        _fieldValue = ((int)RuleMatchField.Any).ToString();
        _modeValue = ((int)RuleMatchMode.Substring).ToString();
        _ruleScopeValue = ((int)RuleScope.Personal).ToString();
        _accountValue = "";
        _minAmount = "";
        _maxAmount = "";
        _amountCurrency = DefaultCurrency();
        _categoryValue = _categories?.FirstOrDefault()?.Id.ToString() ?? "";
        _activeValue = "true";
    }

    private async Task ToggleActiveAsync(CategorizationRuleDto r)
    {
        var updated = await Api.UpdateRuleAsync(r.Id, new CategorizationRuleRequest
        {
            Scope = r.Scope,
            BankAccountId = r.BankAccountId,
            MinAmount = r.MinAmount,
            MaxAmount = r.MaxAmount,
            AmountCurrency = r.AmountCurrency,
            Field = r.Field,
            MatchMode = r.MatchMode,
            Pattern = r.Pattern,
            CategoryId = r.CategoryId,
            Priority = r.Priority,
            IsActive = !r.IsActive,
            Version = r.Version,
        });
        if (updated is null)
            Toasts.ShowError("Změnu se nepodařilo uložit (pravidlo mezitím možná změnil někdo jiný).");
        await LoadRulesAsync();
    }

    private async Task DeleteAsync(CategorizationRuleDto r)
    {
        var dialog = await Dialogs.ShowConfirmationAsync(
            $"Opravdu smazat pravidlo {r.Pattern}? Už zařazené pohyby zůstanou beze změny a pravidlo lze později obnovit.",
            "Smazat", "Zrušit", "Smazání pravidla");
        if ((await dialog.Result).Cancelled)
            return;

        if (await Api.DeleteRuleAsync(r.Id))
            Toasts.ShowSuccess("Pravidlo bylo smazáno.");
        else
            Toasts.ShowError("Pravidlo se nepodařilo smazat.");
        if (_editingId == r.Id)
            ResetForm();
        await LoadRulesAsync();
    }

    private async Task RecategorizeAsync()
    {
        _recategorizing = true;
        try
        {
            var count = await Api.RecategorizeAsync(_scopeValue == "true");
            Toasts.ShowSuccess($"Přepočítáno – zařazeno {count} pohybů.");
            await LoadRulesAsync();
        }
        finally
        {
            _recategorizing = false;
        }
    }

    private static string FieldLabel(RuleMatchField field) => field switch
    {
        RuleMatchField.CounterpartyName => "Protistrana",
        RuleMatchField.Description => "Popis",
        RuleMatchField.VariableSymbol => "Variabilní symbol",
        RuleMatchField.CounterpartyAccount => "Protiúčet",
        RuleMatchField.Any => "Kdekoliv",
        _ => field.ToString(),
    };

    private static string ModeLabel(RuleMatchMode mode) => mode switch
    {
        RuleMatchMode.Substring => "Část textu",
        RuleMatchMode.WholeWord => "Celé slovo",
        RuleMatchMode.Regex => "Regulární výraz",
        _ => mode.ToString(),
    };

    private static string KindLabel(CategoryKind kind) => kind switch
    {
        CategoryKind.Expense => "výdaj",
        CategoryKind.Income => "příjem",
        _ => kind.ToString(),
    };

    private static string ScopeLabel(CategorizationRuleDto r) => r.Scope switch
    {
        RuleScope.Personal => r.OwnerName is { } owner ? $"Osobní · {owner}" : "Osobní",
        RuleScope.Account => r.BankAccountName is { } acc ? $"Účet · {acc}" : "Účet",
        RuleScope.Family => "Globální",
        _ => r.Scope.ToString(),
    };

    /// <summary>Human label for a rule's amount condition, or null when it has none.</summary>
    private static string? AmountLabel(CategorizationRuleDto r)
    {
        if (r.MinAmount is null && r.MaxAmount is null)
            return null;
        var cur = r.AmountCurrency ?? "";
        return (r.MinAmount, r.MaxAmount) switch
        {
            ({ } mn, { } mx) when mn == mx => $"= {mn:0.##} {cur}",
            ({ } mn, { } mx) => $"{mn:0.##}–{mx:0.##} {cur}",
            ({ } mn, null) => $"≥ {mn:0.##} {cur}",
            (null, { } mx) => $"≤ {mx:0.##} {cur}",
            _ => null,
        };
    }

    private string DefaultCurrency()
    {
        if (_ruleScopeValue == ((int)RuleScope.Account).ToString()
            && Guid.TryParse(_accountValue, out var id)
            && _accounts?.FirstOrDefault(a => a.Id == id) is { } acc)
            return acc.Currency;
        return _accounts?.FirstOrDefault()?.Currency ?? "CZK";
    }

    private void OnRuleAccountChanged() => _amountCurrency = DefaultCurrency();

    private static bool TryParseAmount(string s, out decimal? value)
    {
        value = null;
        if (decimal.TryParse(s.Trim().Replace(" ", "").Replace(',', '.'),
                NumberStyles.Number, CultureInfo.InvariantCulture, out var parsed))
        {
            value = parsed;
            return true;
        }
        return false;
    }
}
