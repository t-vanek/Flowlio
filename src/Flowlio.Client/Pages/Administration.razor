@page "/administration"
@attribute [Authorize]
@inject FlowlioApi Api
@inject CurrentUserState CurrentUser
@inject IJSRuntime JS
@inject IDialogService Dialogs
@inject IToastService Toasts

<PageTitle>Administrace – Flowlio</PageTitle>

<h1 class="page-title">Administrace</h1>

@if (_me is null)
{
    <FluentProgressRing />
}
else if (!_canUsers && !_canSysRoles && !_canAudit)
{
    <FluentMessageBar Intent="MessageIntent.Warning">Na administraci nemáte oprávnění.</FluentMessageBar>
}
else
{
    <div class="admin-tabs">
        @if (_canUsers)
        {
            <FluentButton Appearance="@TabAppearance(Tab.Users)" OnClick="@(() => _tab = Tab.Users)">Uživatelské účty</FluentButton>
        }
        @if (_canSysRoles)
        {
            <FluentButton Appearance="@TabAppearance(Tab.SystemRoles)" OnClick="@(() => _tab = Tab.SystemRoles)">Role účtů</FluentButton>
        }
        @if (_canAudit)
        {
            <FluentButton Appearance="@TabAppearance(Tab.Audit)" OnClick="@(() => _tab = Tab.Audit)">Audit</FluentButton>
        }
    </div>

    @if (_tab == Tab.Users && _canUsers)
    {
        @if (_canCreateUsers)
        {
            <FluentCard Class="panel">
                <h2 class="panel-title">Nový uživatel</h2>
                <EditForm Model="_newUser" OnValidSubmit="CreateUserAsync">
                    <DataAnnotationsValidator />
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="10">
                        <div>
                            <FluentTextField @bind-Value="_newUser.Email" Label="E-mail" Style="width:100%" Placeholder="novy@example.com" />
                            <FluentValidationMessage For="@(() => _newUser.Email)" />
                        </div>
                        <FluentTextField @bind-Value="_newUser.DisplayName" Label="Jméno (volitelné)" Style="width:100%" />
                        <div>
                            <FluentTextField @bind-Value="_newUser.Password" TextFieldType="TextFieldType.Password" Label="Počáteční heslo" Style="width:100%" />
                            <FluentValidationMessage For="@(() => _newUser.Password)" />
                        </div>
                        <label class="perm-item">
                            <input type="checkbox" checked="@_newUser.IsAdmin" @onchange="@(e => _newUser.IsAdmin = (bool)(e.Value ?? false))" />
                            <span>Administrátor</span>
                        </label>
                        <label class="perm-item">
                            <input type="checkbox" checked="@_newUser.MustChangePassword" @onchange="@(e => _newUser.MustChangePassword = (bool)(e.Value ?? false))" />
                            <span>Vynutit změnu hesla při prvním přihlášení</span>
                        </label>
                        <FluentButton Type="ButtonType.Submit" Appearance="Appearance.Accent">Vytvořit uživatele</FluentButton>
                    </FluentStack>
                </EditForm>
            </FluentCard>
        }

        <FluentCard Class="panel">
            <h2 class="panel-title">Uživatelské účty</h2>
            <div class="toolbar">
                <FluentTextField @bind-Value="_userSearch" Label="Hledat (e-mail, jméno)" Style="flex:1 1 240px;min-width:220px" />
                <FluentSelect TOption="string" @bind-Value="_userStatus" Label="Stav">
                    <FluentOption TOption="string" Value="">Všechny stavy</FluentOption>
                    <FluentOption TOption="string" Value="active">Aktivní</FluentOption>
                    <FluentOption TOption="string" Value="locked">Zamčené</FluentOption>
                    <FluentOption TOption="string" Value="blocked">Blokované</FluentOption>
                </FluentSelect>
                <div class="toolbar-actions">
                    <FluentButton Appearance="Appearance.Accent" OnClick="SearchUsersAsync">Filtrovat</FluentButton>
                    <FluentButton Appearance="Appearance.Stealth" OnClick="ClearUserFiltersAsync">Zrušit</FluentButton>
                </div>
            </div>
            @if (_canDeleteUsers)
            {
                <FluentButton Appearance="Appearance.Stealth" OnClick="ToggleDeletedAsync">@(_showDeleted ? "Skrýt smazané" : "Zobrazit smazané")</FluentButton>
            }
            @if (_users is null)
            {
                <FluentProgressRing />
            }
            else if (_users.Items.Count == 0)
            {
                <p class="muted">Žádní uživatelé neodpovídají filtru.</p>
            }
            else
            {
                @foreach (var u in _users.Items)
                {
                    <div class="account-row">
                        <div>
                            <div class="account-name">
                                @(string.IsNullOrWhiteSpace(u.DisplayName) ? u.Email : u.DisplayName)
                                @if (u.IsCurrentUser)
                                {
                                    <span class="muted">(vy)</span>
                                }
                                @if (u.Roles.Count > 0)
                                {
                                    <span class="muted">· @string.Join(", ", u.Roles)</span>
                                }
                                @if (u.IsLockedOut)
                                {
                                    <span class="muted">· @LockLabel(u)</span>
                                }
                                @if (u.MustChangePassword)
                                {
                                    <span class="muted">· vyžadována změna hesla</span>
                                }
                                @if (u.TwoFactorEnabled)
                                {
                                    <span class="muted">· 2FA</span>
                                }
                                @if (!u.TwoFactorEnabled && u.Require2faByUtc is { } deadline)
                                {
                                    var expired = deadline < DateTimeOffset.UtcNow;
                                    <span class="muted" style="color:@(expired ? "var(--flowlio-expense)" : "var(--flowlio-warn)");">
                                        · 2FA vyžadováno do @deadline.LocalDateTime.ToString("d.M.yyyy")@(expired ? " (vypršelo)" : "")
                                    </span>
                                }
                            </div>
                            <div class="muted">
                                @u.Email
                                @if (u.Families.Count > 0)
                                {
                                    <text> · @string.Join(", ", u.Families)</text>
                                }
                            </div>
                        </div>
                        <div>
                            <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => ToggleUser(u))">
                                @(_userExpanded == u.Id ? "Skrýt" : "Spravovat")
                            </FluentButton>
                        </div>
                    </div>

                    @if (_userExpanded == u.Id)
                    {
                        <div class="member-edit">
                            @if (u.IsCurrentUser)
                            {
                                <p class="muted">Vlastní účet nelze spravovat zde.</p>
                            }
                            else
                            {
                                @if (_canUserRoles && _systemRoles is not null)
                                {
                                    <h4 class="panel-title">Systémové role</h4>
                                    <div class="perm-grid">
                                        @foreach (var role in _systemRoles.Roles)
                                        {
                                            <label class="perm-item">
                                                <input type="checkbox"
                                                       checked="@_editUserRoles.Contains(role.Name)"
                                                       @onchange="@(e => ToggleUserRole(role.Name, (bool)(e.Value ?? false)))" />
                                                <span>@role.Name</span>
                                            </label>
                                        }
                                    </div>
                                    <FluentButton Appearance="Appearance.Accent" OnClick="@(() => SaveUserRolesAsync(u))">Uložit role</FluentButton>
                                }
                                else
                                {
                                    <p class="muted">Role: @(u.Roles.Count > 0 ? string.Join(", ", u.Roles) : "žádné")</p>
                                }

                                <div class="admin-tabs" style="margin-top:10px;">
                                    @if (_canLockout)
                                    {
                                        <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => LockAsync(u))">Zamknout 24 h</FluentButton>
                                        <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => BlockAsync(u))">Blokovat</FluentButton>
                                        <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => RestoreAsync(u))">Obnovit</FluentButton>
                                    }
                                    @if (_canPasswords)
                                    {
                                        <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => ForcePwdAsync(u))">Vynutit změnu hesla</FluentButton>
                                        @if (u.TwoFactorEnabled)
                                        {
                                            <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => Disable2faAsync(u))">Vypnout 2FA</FluentButton>
                                        }
                                        else
                                        {
                                            @if (u.Require2faByUtc is null)
                                            {
                                                <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => OpenRequire2faAsync(u))">Vyžadovat 2FA…</FluentButton>
                                            }
                                            else
                                            {
                                                var tip = $"Vyžadováno do {u.Require2faByUtc.Value.LocalDateTime:d.M.yyyy HH:mm}";
                                                <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => ClearRequire2faAsync(u))" title="@tip">Zrušit požadavek 2FA</FluentButton>
                                            }
                                        }
                                    }
                                    @if (_canForceLogout)
                                    {
                                        <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => ForceLogoutAsync(u))">Vynutit odhlášení</FluentButton>
                                    }
                                    @if (_canDeleteUsers)
                                    {
                                        <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => DeleteUserAsync(u))">Smazat</FluentButton>
                                    }
                                </div>

                                @if (_canPasswords)
                                {
                                    <EditForm Model="_passwordModel" OnValidSubmit="@(() => SetPasswordAsync(u))">
                                        <DataAnnotationsValidator />
                                        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" VerticalAlignment="VerticalAlignment.Bottom" Style="margin-top:10px;">
                                            <div>
                                                <FluentTextField @bind-Value="_passwordModel.NewPassword" TextFieldType="TextFieldType.Password" Label="Nové heslo" />
                                                <FluentValidationMessage For="@(() => _passwordModel.NewPassword)" />
                                            </div>
                                            <FluentButton Type="ButtonType.Submit" Appearance="Appearance.Accent">Nastavit heslo</FluentButton>
                                        </FluentStack>
                                    </EditForm>
                                }
                            }
                        </div>
                    }
                }
            }
            @if (_users is not null && _users.TotalCount > _users.PageSize)
            {
                <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" VerticalAlignment="VerticalAlignment.Center" Style="margin-top:10px;">
                    <FluentButton Appearance="Appearance.Stealth" Disabled="@(_usersPage <= 1)" OnClick="@(() => ChangeUsersPageAsync(-1))">Předchozí</FluentButton>
                    <span class="muted">Strana @_users.Page z @UsersTotalPages · celkem @_users.TotalCount</span>
                    <FluentButton Appearance="Appearance.Stealth" Disabled="@(_usersPage >= UsersTotalPages)" OnClick="@(() => ChangeUsersPageAsync(1))">Další</FluentButton>
                </FluentStack>
            }
        </FluentCard>

        @if (_showDeleted && _canDeleteUsers)
        {
            <FluentCard Class="panel">
                <h2 class="panel-title">Smazané účty</h2>
                <div class="toolbar">
                    <FluentTextField @bind-Value="_deletedSearch" Label="Hledat (e-mail, jméno)" Style="flex:1 1 240px;min-width:220px" />
                    <div class="toolbar-actions">
                        <FluentButton Appearance="Appearance.Accent" OnClick="SearchDeletedAsync">Filtrovat</FluentButton>
                        <FluentButton Appearance="Appearance.Stealth" OnClick="ClearDeletedFiltersAsync">Zrušit</FluentButton>
                    </div>
                </div>
                @if (_deletedUsers is null)
                {
                    <FluentProgressRing />
                }
                else if (_deletedUsers.Items.Count == 0)
                {
                    <p class="muted">@(string.IsNullOrWhiteSpace(_deletedSearch) ? "Žádné smazané účty." : "Žádné smazané účty neodpovídají filtru.")</p>
                }
                else
                {
                    @foreach (var u in _deletedUsers.Items)
                    {
                        <div class="account-row">
                            <div>
                                <div class="account-name">@(string.IsNullOrWhiteSpace(u.DisplayName) ? u.Email : u.DisplayName)</div>
                                <div class="muted">@u.Email · smazáno @u.DeletedAtUtc?.LocalDateTime.ToString("d.M.yyyy")</div>
                            </div>
                            <div>
                                <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => UndeleteAsync(u))">Obnovit účet</FluentButton>
                                <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => PurgeAsync(u))">Trvale odstranit</FluentButton>
                            </div>
                        </div>
                    }
                    @if (_deletedUsers.TotalCount > _deletedUsers.PageSize)
                    {
                        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" VerticalAlignment="VerticalAlignment.Center" Style="margin-top:10px;">
                            <FluentButton Appearance="Appearance.Stealth" Disabled="@(_deletedPage <= 1)" OnClick="@(() => ChangeDeletedPageAsync(-1))">Předchozí</FluentButton>
                            <span class="muted">Strana @_deletedUsers.Page z @DeletedTotalPages · celkem @_deletedUsers.TotalCount</span>
                            <FluentButton Appearance="Appearance.Stealth" Disabled="@(_deletedPage >= DeletedTotalPages)" OnClick="@(() => ChangeDeletedPageAsync(1))">Další</FluentButton>
                        </FluentStack>
                    }
                }
            </FluentCard>
        }
    }

    @if (_tab == Tab.SystemRoles && _canSysRoles)
    {
        <FluentCard Class="panel">
            <h2 class="panel-title">Nová role účtů</h2>
            <EditForm Model="_newRoleModel" OnValidSubmit="CreateSystemRoleAsync">
                <DataAnnotationsValidator />
                <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" VerticalAlignment="VerticalAlignment.Bottom">
                    <div>
                        <FluentTextField @bind-Value="_newRoleModel.Name" Label="Název role" Placeholder="např. Podpora" />
                        <FluentValidationMessage For="@(() => _newRoleModel.Name)" />
                    </div>
                    <FluentButton Type="ButtonType.Submit" Appearance="Appearance.Accent">Vytvořit roli</FluentButton>
                </FluentStack>
            </EditForm>
        </FluentCard>

        <FluentCard Class="panel">
            <h2 class="panel-title">Role účtů a jejich oprávnění</h2>
            <p class="muted">Co smí role ve správě uživatelských účtů. Administrátor má vždy vše.</p>
            @if (_systemRoles is null)
            {
                <FluentProgressRing />
            }
            else
            {
                @foreach (var role in _systemRoles.Roles)
                {
                    <div class="role-block">
                        <h3 class="panel-title">@role.Name @(role.IsAdministrator ? "(neměnné)" : "") · @role.UserCount uživatelů</h3>
                        <div class="perm-grid">
                            @foreach (var p in _systemRoles.AllPermissions)
                            {
                                <label class="perm-item">
                                    <input type="checkbox"
                                           checked="@HasSysPerm(role.RoleId, p)"
                                           disabled="@role.IsAdministrator"
                                           @onchange="@(e => ToggleSysPerm(role.RoleId, p, (bool)(e.Value ?? false)))" />
                                    <span>@SystemPermLabel(p)</span>
                                </label>
                            }
                        </div>
                        @if (!role.IsAdministrator)
                        {
                            <EditForm Model="_renameModel" OnValidSubmit="@(() => RenameSysRoleAsync(role.RoleId))">
                                <DataAnnotationsValidator />
                                <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" VerticalAlignment="VerticalAlignment.Bottom">
                                    <FluentButton Type="ButtonType.Button" Appearance="Appearance.Accent" OnClick="@(() => SaveSysRoleAsync(role.RoleId))">Uložit oprávnění</FluentButton>
                                    <div>
                                        <FluentTextField @bind-Value="_renameModel.Name" Label="Přejmenovat na" />
                                        <FluentValidationMessage For="@(() => _renameModel.Name)" />
                                    </div>
                                    <FluentButton Type="ButtonType.Submit" Appearance="Appearance.Stealth">Přejmenovat</FluentButton>
                                    <FluentButton Type="ButtonType.Button" Appearance="Appearance.Stealth" OnClick="@(() => DeleteSysRoleAsync(role.RoleId))">Smazat roli</FluentButton>
                                </FluentStack>
                            </EditForm>
                        }
                    </div>
                }
            }
        </FluentCard>
    }

    @if (_tab == Tab.Audit && _canAudit)
    {
        <FluentCard Class="panel">
            <h2 class="panel-title">Audit log</h2>
            <div class="toolbar">
                <FluentTextField @bind-Value="_auditSearch" Label="Hledat (aktér, cíl, popis)" Style="flex:1 1 240px;min-width:220px" />
                <FluentSelect TOption="string" @bind-Value="_auditAction" Label="Akce">
                    <FluentOption TOption="string" Value="">Všechny akce</FluentOption>
                    @foreach (var a in _auditActions)
                    {
                        <FluentOption TOption="string" Value="@a">@AuditActionLabel(a)</FluentOption>
                    }
                </FluentSelect>
                <FluentDatePicker @bind-Value="_auditFrom" Label="Od" />
                <FluentDatePicker @bind-Value="_auditTo" Label="Do" />
                <div class="toolbar-actions">
                    <FluentButton Appearance="Appearance.Accent" OnClick="SearchAuditAsync">Filtrovat</FluentButton>
                    <FluentButton Appearance="Appearance.Stealth" OnClick="ClearAuditFiltersAsync">Zrušit</FluentButton>
                    <FluentButton Appearance="Appearance.Neutral" OnClick="ExportAuditAsync" Loading="_auditExporting">⬇ Export CSV</FluentButton>
                </div>
            </div>
            @if (_audit is null)
            {
                <FluentProgressRing />
            }
            else if (_audit.Items.Count == 0)
            {
                <p class="muted">Žádné záznamy.</p>
            }
            else
            {
                @foreach (var e in _audit.Items)
                {
                    <div class="account-row audit-row" @onclick="@(() => OpenAuditDetail(e))" role="button" tabindex="0">
                        <div>
                            <div class="account-name">@AuditActionLabel(e.Action)@(e.TargetName is not null ? $" · {e.TargetName}" : "")</div>
                            <div class="muted">
                                @e.OccurredAt.LocalDateTime.ToString("d.M.yyyy HH:mm") · @(e.ActorName ?? "systém")
                                @if (!string.IsNullOrWhiteSpace(e.Details))
                                {
                                    <text> · @e.Details</text>
                                }
                            </div>
                        </div>
                        <span class="muted">›</span>
                    </div>
                }
                <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" VerticalAlignment="VerticalAlignment.Center" Style="margin-top:10px;">
                    <FluentButton Appearance="Appearance.Stealth" Disabled="@(_auditPage <= 1)" OnClick="@(() => ChangeAuditPageAsync(-1))">Předchozí</FluentButton>
                    <span class="muted">Strana @_audit.Page · celkem @_audit.TotalCount</span>
                    <FluentButton Appearance="Appearance.Stealth" Disabled="@(_auditPage * _audit.PageSize >= _audit.TotalCount)" OnClick="@(() => ChangeAuditPageAsync(1))">Další</FluentButton>
                </FluentStack>
            }
        </FluentCard>

        @if (_auditDetail is { } d)
        {
            <div class="profile-backdrop" @onclick="CloseAuditDetail"></div>
            <div class="audit-modal" role="dialog" aria-modal="true">
                <h3 class="panel-title">@AuditActionLabel(d.Action)</h3>
                <dl class="audit-detail">
                    <dt>Kdy</dt>
                    <dd>@d.OccurredAt.LocalDateTime.ToString("dddd d.M.yyyy HH:mm:ss") <span class="muted">(UTC @d.OccurredAt.UtcDateTime.ToString("HH:mm:ss"))</span></dd>
                    <dt>Aktér</dt>
                    <dd>@(d.ActorName ?? "systém")</dd>
                    <dt>Akce</dt>
                    <dd><code>@d.Action</code></dd>
                    @if (d.TargetType is not null)
                    {
                        <dt>Cíl</dt>
                        <dd>@d.TargetType@(d.TargetName is not null ? $" · {d.TargetName}" : "")</dd>
                    }
                    @if (!string.IsNullOrWhiteSpace(d.Details))
                    {
                        <dt>Popis</dt>
                        <dd>@d.Details</dd>
                    }
                    <dt>ID záznamu</dt>
                    <dd><code>@d.Id</code></dd>
                </dl>
                <div class="btn-row">
                    <FluentButton Appearance="Appearance.Accent" OnClick="CloseAuditDetail">Zavřít</FluentButton>
                </div>
            </div>
        }
    }

}

@code {
    private enum Tab { Users, SystemRoles, Audit }

    private CurrentUserDto? _me;
    private bool _canUsers;
    private bool _canCreateUsers;
    private bool _canUserRoles;
    private bool _canLockout;
    private bool _canPasswords;
    private bool _canForceLogout;
    private bool _canDeleteUsers;
    private bool _canSysRoles;
    private bool _canAudit;
    private Tab _tab;

    private const int AdminPageSize = 25;
    private AdminUserPageDto? _users;
    private int _usersPage = 1;
    private Guid? _userExpanded;
    private HashSet<string> _editUserRoles = new();
    private CreateUserRequest _newUser = new();
    private AdminSetPasswordRequest _passwordModel = new();
    private string _userSearch = "";
    private string _userStatus = "";
    private bool _showDeleted;
    private AdminUserPageDto? _deletedUsers;
    private int _deletedPage = 1;
    private string _deletedSearch = "";

    private int UsersTotalPages => _users is null || _users.PageSize == 0
        ? 1 : Math.Max(1, (int)Math.Ceiling((double)_users.TotalCount / _users.PageSize));
    private int DeletedTotalPages => _deletedUsers is null || _deletedUsers.PageSize == 0
        ? 1 : Math.Max(1, (int)Math.Ceiling((double)_deletedUsers.TotalCount / _deletedUsers.PageSize));

    private SystemRolesDto? _systemRoles;
    private readonly Dictionary<Guid, HashSet<SystemPermission>> _sysRolePerms = new();
    private CreateSystemRoleRequest _newRoleModel = new();
    private RenameSystemRoleRequest _renameModel = new();

    private AuditPageDto? _audit;
    private string _auditSearch = "";
    private string _auditAction = "";
    private DateTime? _auditFrom;
    private DateTime? _auditTo;
    private IReadOnlyList<string> _auditActions = [];
    private AuditEntryDto? _auditDetail;
    private bool _auditExporting;
    private int _auditPage = 1;

    protected override async Task OnInitializedAsync()
    {
        _me = await CurrentUser.GetAsync();
        if (_me is null)
            return;

        ApplyPermissions();
        EnsureValidTab();

        if (_canUsers)
        {
            await LoadUsersAsync();
            await LoadSystemRolesAsync();
        }
        if (_canAudit)
        {
            _auditActions = await Api.GetAuditActionsAsync();
            await LoadAuditAsync();
        }
    }

    private void ApplyPermissions()
    {
        bool S(SystemPermission p) => _me?.CanSystem(p) ?? false;
        _canUsers       = S(SystemPermission.ViewUsers);
        _canCreateUsers = S(SystemPermission.CreateUsers);
        _canUserRoles   = S(SystemPermission.ManageUserRoles);
        _canLockout     = S(SystemPermission.ManageUserLockout);
        _canPasswords   = S(SystemPermission.ManageUserPasswords);
        _canForceLogout = S(SystemPermission.ForceUserLogout);
        _canDeleteUsers = S(SystemPermission.DeleteUsers);
        _canSysRoles    = S(SystemPermission.ManageSystemRoles);
        _canAudit       = S(SystemPermission.ViewAuditLog);
    }

    private void EnsureValidTab()
    {
        if (_tab == Tab.Users && _canUsers) return;
        if (_tab == Tab.SystemRoles && _canSysRoles) return;
        if (_tab == Tab.Audit && _canAudit) return;
        _tab = _canUsers ? Tab.Users
            : _canSysRoles ? Tab.SystemRoles
            : Tab.Audit;
    }

    private async Task LoadSystemRolesAsync()
    {
        _systemRoles = await Api.GetSystemRolesAsync();
        _sysRolePerms.Clear();
        if (_systemRoles is not null)
            foreach (var r in _systemRoles.Roles)
                _sysRolePerms[r.RoleId] = r.Permissions.ToHashSet();
    }

    private async Task LoadAuditAsync()
        => _audit = await Api.GetAuditAsync(_auditSearch, NullIfBlank(_auditAction), ToOffset(_auditFrom), ToOffset(_auditTo, endOfDay: true), _auditPage);

    private static string? NullIfBlank(string? s) => string.IsNullOrWhiteSpace(s) ? null : s;

    private static DateTimeOffset? ToOffset(DateTime? d, bool endOfDay = false)
        => d is null ? null : new DateTimeOffset(endOfDay ? d.Value.Date.AddDays(1) : d.Value.Date, TimeSpan.Zero);

    private async Task SearchAuditAsync()
    {
        _auditPage = 1;
        await LoadAuditAsync();
    }

    private async Task ClearAuditFiltersAsync()
    {
        _auditSearch = "";
        _auditAction = "";
        _auditFrom = null;
        _auditTo = null;
        _auditPage = 1;
        await LoadAuditAsync();
    }

    private void OpenAuditDetail(AuditEntryDto entry) => _auditDetail = entry;
    private void CloseAuditDetail() => _auditDetail = null;

    private async Task ExportAuditAsync()
    {
        if (_auditExporting) return;
        _auditExporting = true;
        try
        {
            var result = await Api.ExportAuditCsvAsync(_auditSearch, NullIfBlank(_auditAction), ToOffset(_auditFrom), ToOffset(_auditTo, endOfDay: true));
            if (result is { } r)
                await JS.InvokeVoidAsync("flowlioDownload.fromBytes", r.FileName, Convert.ToBase64String(r.Bytes), "text/csv;charset=utf-8");
        }
        finally
        {
            _auditExporting = false;
        }
    }

    private async Task ChangeAuditPageAsync(int delta)
    {
        _auditPage = Math.Max(1, _auditPage + delta);
        await LoadAuditAsync();
    }

    // ---- System role matrix ----
    private bool HasSysPerm(Guid roleId, SystemPermission p) =>
        _sysRolePerms.TryGetValue(roleId, out var set) && set.Contains(p);

    private void ToggleSysPerm(Guid roleId, SystemPermission p, bool on)
    {
        if (!_sysRolePerms.TryGetValue(roleId, out var set))
            _sysRolePerms[roleId] = set = new HashSet<SystemPermission>();
        if (on) set.Add(p); else set.Remove(p);
    }

    private async Task RunSysRolesActionAsync(Func<Task<bool>> action, string okMessage)
    {
        if (await action())
            Toasts.ShowSuccess(okMessage);
        else
            Toasts.ShowError("Operace se nezdařila.");
        await LoadSystemRolesAsync();
    }

    private async Task CreateSystemRoleAsync()
    {
        await RunSysRolesActionAsync(() => Api.CreateSystemRoleAsync(_newRoleModel.Name), "Role vytvořena.");
        _newRoleModel = new();
    }

    private Task SaveSysRoleAsync(Guid roleId) =>
        RunSysRolesActionAsync(
            () => Api.SetSystemRolePermissionsAsync(roleId, (_sysRolePerms.TryGetValue(roleId, out var s) ? s : new()).ToList()),
            "Oprávnění role uložena.");

    private async Task RenameSysRoleAsync(Guid roleId)
    {
        await RunSysRolesActionAsync(() => Api.RenameSystemRoleAsync(roleId, _renameModel.Name), "Role přejmenována.");
        _renameModel = new();
    }

    private async Task DeleteSysRoleAsync(Guid roleId)
    {
        var name = _systemRoles?.Roles.FirstOrDefault(r => r.RoleId == roleId)?.Name ?? "roli";
        if (!await ConfirmAsync($"Opravdu smazat roli účtů: {name}? Uživatelé tuto roli ztratí.", "Smazat", "Smazání role"))
            return;
        await RunSysRolesActionAsync(() => Api.DeleteSystemRoleAsync(roleId), "Role smazána.");
    }

    // ---- Users ----
    private void ToggleUser(AdminUserDto u)
    {
        if (_userExpanded == u.Id)
        {
            _userExpanded = null;
            return;
        }
        _userExpanded = u.Id;
        _editUserRoles = new HashSet<string>(u.Roles, StringComparer.Ordinal);
    }

    private void ToggleUserRole(string roleName, bool on)
    {
        if (on) _editUserRoles.Add(roleName); else _editUserRoles.Remove(roleName);
    }

    private Task SaveUserRolesAsync(AdminUserDto u) =>
        RunUserActionAsync(() => Api.SetUserRolesAsync(u.Id, _editUserRoles.ToList()), "Role uloženy.");

    private async Task RunUserActionAsync(Func<Task<bool>> action, string okMessage)
    {
        if (await action())
            Toasts.ShowSuccess(okMessage);
        else
            Toasts.ShowError("Operace se nezdařila.");
        await LoadUsersAsync();
    }

    private async Task<bool> ConfirmAsync(string message, string confirm, string title)
    {
        var dialog = await Dialogs.ShowConfirmationAsync(message, confirm, "Zrušit", title);
        return !(await dialog.Result).Cancelled;
    }

    private static string UserName(AdminUserDto u) =>
        string.IsNullOrWhiteSpace(u.DisplayName) ? (u.Email ?? "uživatel") : u.DisplayName;

    // Reload the current page; if it fell past the end (e.g. after a delete), step back to the last page.
    private async Task LoadUsersAsync()
    {
        _users = await Api.GetAdminUsersAsync(_usersPage, AdminPageSize, _userSearch, _userStatus);
        if (_usersPage > UsersTotalPages)
        {
            _usersPage = UsersTotalPages;
            _users = await Api.GetAdminUsersAsync(_usersPage, AdminPageSize, _userSearch, _userStatus);
        }
    }

    private Task ChangeUsersPageAsync(int delta)
    {
        _usersPage = Math.Clamp(_usersPage + delta, 1, UsersTotalPages);
        return LoadUsersAsync();
    }

    private Task SearchUsersAsync()
    {
        _usersPage = 1;
        return LoadUsersAsync();
    }

    private Task ClearUserFiltersAsync()
    {
        _userSearch = "";
        _userStatus = "";
        _usersPage = 1;
        return LoadUsersAsync();
    }

    private async Task LoadDeletedAsync()
    {
        _deletedUsers = await Api.GetDeletedUsersAsync(_deletedPage, AdminPageSize, _deletedSearch);
        if (_deletedPage > DeletedTotalPages)
        {
            _deletedPage = DeletedTotalPages;
            _deletedUsers = await Api.GetDeletedUsersAsync(_deletedPage, AdminPageSize, _deletedSearch);
        }
    }

    private Task ChangeDeletedPageAsync(int delta)
    {
        _deletedPage = Math.Clamp(_deletedPage + delta, 1, DeletedTotalPages);
        return LoadDeletedAsync();
    }

    private Task SearchDeletedAsync()
    {
        _deletedPage = 1;
        return LoadDeletedAsync();
    }

    private Task ClearDeletedFiltersAsync()
    {
        _deletedSearch = "";
        _deletedPage = 1;
        return LoadDeletedAsync();
    }

    private async Task CreateUserAsync()
    {
        if (string.IsNullOrWhiteSpace(_newUser.DisplayName))
            _newUser.DisplayName = null;
        if (await Api.CreateUserAsync(_newUser))
        {
            Toasts.ShowSuccess("Uživatel vytvořen.");
            _newUser = new();
        }
        else
        {
            Toasts.ShowError("Uživatele se nepodařilo vytvořit (e-mail už existuje nebo slabé heslo).");
        }
        await LoadUsersAsync();
    }

    private Task LockAsync(AdminUserDto u) =>
        RunUserActionAsync(() => Api.LockUserAsync(u.Id, 24 * 60), "Účet zamčen na 24 hodin.");

    private async Task BlockAsync(AdminUserDto u)
    {
        if (!await ConfirmAsync($"Opravdu zablokovat účet: {UserName(u)}? Uživatel se nebude moci přihlásit, dokud jej neobnovíte.", "Blokovat", "Blokace účtu"))
            return;
        await RunUserActionAsync(() => Api.BlockUserAsync(u.Id), "Účet zablokován.");
    }

    private Task RestoreAsync(AdminUserDto u) =>
        RunUserActionAsync(() => Api.RestoreUserAsync(u.Id), "Účet obnoven.");

    private Task ForcePwdAsync(AdminUserDto u) =>
        RunUserActionAsync(() => Api.ForcePasswordChangeAsync(u.Id), "Při příštím přihlášení bude vyžadována změna hesla.");

    private async Task Disable2faAsync(AdminUserDto u)
    {
        if (!await ConfirmAsync($"Opravdu vypnout dvoufaktorové ověření pro: {UserName(u)}? Sníží se tím zabezpečení účtu.", "Vypnout 2FA", "Vypnutí 2FA"))
            return;
        await RunUserActionAsync(() => Api.DisableUser2faAsync(u.Id), "Dvoufaktorové ověření vypnuto.");
    }

    private async Task OpenRequire2faAsync(AdminUserDto u)
    {
        // Lightweight prompt: ask for the number of days. Days from now → UTC deadline.
        // Keeps the admin UI a single click + numeric entry instead of a full dialog.
        var raw = await JS.InvokeAsync<string?>("prompt", $"Za kolik dní musí {u.Email ?? "uživatel"} mít zapnuté 2FA?", "7");
        if (string.IsNullOrWhiteSpace(raw)) return;
        if (!int.TryParse(raw, out var days) || days < 1 || days > 365)
        {
            Toasts.ShowError("Zadejte počet dní mezi 1 a 365.");
            return;
        }
        var deadline = DateTimeOffset.UtcNow.AddDays(days);
        await RunUserActionAsync(() => Api.Require2faAsync(u.Id, deadline),
            $"Zapnutí 2FA vyžadováno do {deadline.LocalDateTime:d.M.yyyy HH:mm}.");
    }

    private Task ClearRequire2faAsync(AdminUserDto u) =>
        RunUserActionAsync(() => Api.Require2faAsync(u.Id, null), "Požadavek na 2FA zrušen.");

    private async Task ForceLogoutAsync(AdminUserDto u)
    {
        if (!await ConfirmAsync($"Opravdu vynutit odhlášení uživatele: {UserName(u)}? Bude odhlášen při nejbližší obnově relace.", "Odhlásit", "Vynucené odhlášení"))
            return;
        await RunUserActionAsync(() => Api.ForceLogoutAsync(u.Id), "Uživatel bude odhlášen při nejbližší obnově relace.");
    }

    private async Task DeleteUserAsync(AdminUserDto u)
    {
        if (!await ConfirmAsync($"Opravdu smazat účet: {UserName(u)}? Účet půjde obnovit ze seznamu smazaných.", "Smazat", "Smazání účtu"))
            return;
        await RunUserActionAsync(() => Api.DeleteUserAsync(u.Id), "Účet smazán (lze obnovit).");
    }

    private async Task ToggleDeletedAsync()
    {
        _showDeleted = !_showDeleted;
        if (_showDeleted)
            await LoadDeletedAsync();
    }

    private async Task ReloadDeletedAsync()
    {
        if (_showDeleted)
            await LoadDeletedAsync();
    }

    private async Task UndeleteAsync(AdminUserDto u)
    {
        await RunUserActionAsync(() => Api.UndeleteUserAsync(u.Id), "Účet obnoven.");
        await ReloadDeletedAsync();
    }

    private async Task PurgeAsync(AdminUserDto u)
    {
        if (!await ConfirmAsync($"Opravdu trvale odstranit účet: {UserName(u)}? Tuto akci nelze vrátit zpět.", "Trvale odstranit", "Trvalé odstranění účtu"))
            return;
        await RunUserActionAsync(() => Api.PurgeUserAsync(u.Id), "Účet trvale odstraněn.");
        await ReloadDeletedAsync();
    }

    private async Task SetPasswordAsync(AdminUserDto u)
    {
        if (await Api.SetUserPasswordAsync(u.Id, _passwordModel))
        {
            Toasts.ShowSuccess("Heslo nastaveno; uživatel si jej při přihlášení změní.");
            _passwordModel = new();
        }
        else
        {
            Toasts.ShowError("Heslo se nepodařilo nastavit (slabé heslo?).");
        }
        await LoadUsersAsync();
    }

