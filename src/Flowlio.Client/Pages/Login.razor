@page "/login"
@layout EmptyLayout
@inject FlowlioApi Api
@inject NavigationManager Navigation

<PageTitle>Přihlášení – Flowlio</PageTitle>

<div class="auth-shell">
    <FluentCard Class="auth-card">
        <div class="auth-logo">₣ Flowlio</div>
        <h1 class="auth-title">Přihlášení</h1>
        <p class="auth-subtitle">Rodinný rozpočet pod kontrolou.</p>

        <FluentStack Orientation="Orientation.Vertical" VerticalGap="14">
            <FluentTextField @bind-Value="_email" Label="E-mail" Style="width:100%" Placeholder="rodina@flowlio.local" />
            <FluentTextField @bind-Value="_password" Label="Heslo" TextFieldType="TextFieldType.Password" Style="width:100%" />

            @if (_error is not null)
            {
                <FluentMessageBar Intent="MessageIntent.Error">@_error</FluentMessageBar>
            }

            <FluentButton Appearance="Appearance.Accent" OnClick="SubmitAsync" Loading="_busy" Style="width:100%">
                Přihlásit se
            </FluentButton>

            <div class="auth-switch">
                Nemáte účet? <a href="register">Zaregistrujte se</a>
            </div>
        </FluentStack>
    </FluentCard>
</div>

@code {
    private string _email = "rodina@flowlio.local";
    private string _password = "Flowlio123!";
    private string? _error;
    private bool _busy;

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private async Task SubmitAsync()
    {
        _busy = true;
        _error = null;
        try
        {
            if (await Api.LoginAsync(_email, _password))
                Navigation.NavigateTo(string.IsNullOrWhiteSpace(ReturnUrl) ? "" : Uri.UnescapeDataString(ReturnUrl));
            else
                _error = "Přihlášení se nezdařilo. Zkontrolujte e-mail a heslo.";
        }
        finally
        {
            _busy = false;
        }
    }
}
