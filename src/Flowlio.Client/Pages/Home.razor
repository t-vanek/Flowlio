@page "/"
@attribute [Authorize]
@using ApexCharts
@inject FlowlioApi Api
@inject IJSRuntime JS
@inject CurrentUserState CurrentUser

<PageTitle>Přehled – Flowlio</PageTitle>

<h1 class="page-title">Přehled</h1>

@if (!_canView)
{
    <FluentCard Class="panel">
        <FluentMessageBar Intent="MessageIntent.Warning">Nemáte oprávnění zobrazit finance této rodiny.</FluentMessageBar>
    </FluentCard>
}
else if (_summary is null)
{
    <FluentProgressRing />
}
else
{
    <div class="kpi-grid">
        <FluentCard Class="kpi-card">
            <div class="kpi-label">Celkový zůstatek</div>
            <div class="kpi-value">@Formatting.Money(_summary.TotalBalance, _summary.Currency)</div>
        </FluentCard>
        <FluentCard Class="kpi-card">
            <div class="kpi-label">Příjmy tento měsíc</div>
            <div class="kpi-value income">@Formatting.Money(_summary.IncomeThisMonth, _summary.Currency)</div>
        </FluentCard>
        <FluentCard Class="kpi-card">
            <div class="kpi-label">Výdaje tento měsíc</div>
            <div class="kpi-value expense">@Formatting.Money(_summary.ExpenseThisMonth, _summary.Currency)</div>
        </FluentCard>
        <FluentCard Class="kpi-card">
            <div class="kpi-label">Bilance měsíce</div>
            <div class="kpi-value @(_summary.NetThisMonth >= 0 ? "income" : "expense")">@Formatting.Money(_summary.NetThisMonth, _summary.Currency)</div>
        </FluentCard>
    </div>

    @if (_summary.Unconverted.Count > 0)
    {
        <FluentMessageBar Intent="MessageIntent.Warning" Style="margin-bottom:12px">
            Některé částky nejsou v součtech zahrnuty, protože chybí kurz k @_summary.Currency:
            @string.Join(", ", _summary.Unconverted.Select(u => Formatting.Money(u.Amount, u.Currency)))
        </FluentMessageBar>
    }

    <div class="panel-grid">
        <FluentCard Class="panel">
            <div class="panel-head">
                <h2 class="panel-title">Výdaje podle kategorií</h2>
                <PeriodSelector Value="_catPeriod" ValueChanged="SetCatPeriodAsync" />
            </div>
            @if (_catLoading)
            {
                <FluentProgressRing />
            }
            else if (_catData.Count == 0)
            {
                <p class="muted">V tomto období žádné kategorizované výdaje.</p>
            }
            else
            {
                <ApexChart @key="_catPeriod" TItem="CategorySpendDto" Options="_donutOptions" Height="260">
                    <ApexPointSeries TItem="CategorySpendDto"
                                     Items="_catData"
                                     Name="Výdaje"
                                     SeriesType="SeriesType.Donut"
                                     XValue="@(c => c.CategoryName)"
                                     YValue="@(c => (decimal?)Math.Abs(c.Amount))" />
                </ApexChart>
                <div class="chart-legend">
                    @foreach (var c in _catData)
                    {
                        <div class="bar-row">
                            <span class="bar-dot" style="background:@c.Color"></span>
                            <span class="bar-name">@c.CategoryName</span>
                            <span class="bar-amount">@Formatting.Money(c.Amount, _summary.Currency)</span>
                        </div>
                    }
                </div>
            }
        </FluentCard>

        <FluentCard Class="panel">
            <div class="panel-head">
                <h2 class="panel-title">Příjmy vs. výdaje</h2>
                <PeriodSelector Value="_flowPeriod" ValueChanged="SetFlowPeriodAsync" />
            </div>
            @if (_flowLoading)
            {
                <FluentProgressRing />
            }
            else
            {
                <ApexChart @key="_flowPeriod" TItem="FlowPoint" Options="_barOptions" Height="260">
                    <ApexPointSeries TItem="FlowPoint"
                                     Items="_flow"
                                     Name="Částka"
                                     SeriesType="SeriesType.Bar"
                                     XValue="@(p => p.Label)"
                                     YValue="@(p => (decimal?)p.Value)" />
                </ApexChart>
            }
        </FluentCard>

        <FluentCard Class="panel">
            <h2 class="panel-title">Nadcházející platby (30 dní)</h2>
            @if (_summary.Upcoming.Count == 0)
            {
                <p class="muted">Žádné naplánované platby.</p>
            }
            else
            {
                @foreach (var u in _summary.Upcoming)
                {
                    <div class="bar-row">
                        <span class="bar-name">@u.Name</span>
                        <span class="muted">@Formatting.Date(u.DueDate)</span>
                        <span class="bar-amount expense">@Formatting.Money(u.Amount, u.Currency)</span>
                    </div>
                }
            }
        </FluentCard>

        @if (_rates is { Rates.Count: > 0 })
        {
            <FluentCard Class="panel">
                <h2 class="panel-title">Kurzy měn</h2>
                @if (_rates.AsOf is { } asOf)
                {
                    <p class="muted">ČNB k @Formatting.Date(asOf)</p>
                }
                @foreach (var r in _rates.Rates)
                {
                    <div class="bar-row">
                        <span class="bar-name">1 @r.Currency</span>
                        <span class="bar-amount">@Formatting.Money(r.PerUnitInBase, _rates.BaseCurrency)</span>
                    </div>
                }
            </FluentCard>
        }

        @if (_budgets is { Count: > 0 } || _goals is { Count: > 0 })
        {
            <FluentCard Class="panel">
                <h2 class="panel-title">Rozpočty a cíle</h2>
                @foreach (var b in (_budgets ?? []).Take(3))
                {
                    var pct = b.Amount == 0 ? 0 : (double)(b.Spent / b.Amount);
                    <div class="bar-row">
                        <span class="bar-name">@b.CategoryName</span>
                        <span class="bar-amount @(pct >= 1 ? "expense" : "")">@Formatting.Money(b.Spent, b.Currency) / @Formatting.Money(b.Amount, b.Currency)</span>
                    </div>
                }
                @if (_goals is { Count: > 0 })
                {
                    var g = _goals[0];
                    var gp = g.TargetAmount == 0 ? 0 : (double)(g.Saved / g.TargetAmount);
                    <div class="bar-row">
                        <span class="bar-name">🎯 @g.Name</span>
                        <span class="bar-amount">@((Math.Clamp(gp, 0, 1) * 100).ToString("0")) %</span>
                    </div>
                }
                <a href="budgets" class="muted">Spravovat rozpočty a cíle →</a>
            </FluentCard>
        }
    </div>
}

@code {
    private DashboardSummaryDto? _summary;
    private IReadOnlyList<BudgetDto>? _budgets;
    private IReadOnlyList<GoalDto>? _goals;
    private ExchangeRatesDto? _rates;
    private bool _canView;
    private ApexChartOptions<CategorySpendDto> _donutOptions = new();
    private ApexChartOptions<FlowPoint> _barOptions = new();
    private List<FlowPoint> _flow = [];

    private string _catPeriod = "month";
    private IReadOnlyList<CategorySpendDto> _catData = [];
    private bool _catLoading;

    private string _flowPeriod = "month";
    private bool _flowLoading;

    private sealed record FlowPoint(string Label, decimal Value);

    protected override async Task OnInitializedAsync()
    {
        _canView = await CurrentUser.CanAsync(Permission.ViewFinances);
        if (!_canView)
            return;

        _summary = await Api.GetDashboardAsync();
        _budgets = await Api.GetBudgetsAsync();
        _goals = await Api.GetGoalsAsync();
        _rates = await Api.GetExchangeRatesAsync();

        var effective = await JS.InvokeAsync<string>("flowlioTheme.effective");
        var mode = effective == "dark" ? Mode.Dark : Mode.Light;

        _donutOptions = new ApexChartOptions<CategorySpendDto>
        {
            Chart = new Chart { Background = "transparent", FontFamily = "inherit" },
            Theme = new Theme { Mode = mode },
            Legend = new Legend { Position = LegendPosition.Bottom },
            DataLabels = new DataLabels { Enabled = false },
        };
        await LoadCategoriesAsync();

        await LoadFlowAsync();

        _barOptions = new ApexChartOptions<FlowPoint>
        {
            Chart = new Chart { Background = "transparent", FontFamily = "inherit", Toolbar = new Toolbar { Show = false } },
            Theme = new Theme { Mode = mode },
            Colors = ["#16a34a", "#dc2626", "#2563eb"],
            PlotOptions = new PlotOptions { Bar = new PlotOptionsBar { Distributed = true, BorderRadius = 6, ColumnWidth = "45%" } },
            Legend = new Legend { Show = false },
            DataLabels = new DataLabels { Enabled = false },
        };
    }

    private async Task SetCatPeriodAsync(string period)
    {
        if (_catPeriod == period)
            return;
        _catPeriod = period;
        await LoadCategoriesAsync();
    }

    // Loads expense-by-category for the selected period from the server and refreshes the donut's colours.
    private async Task LoadCategoriesAsync()
    {
        _catLoading = true;
        StateHasChanged();
        _catData = await Api.GetCategorySpendAsync(_catPeriod);
        _donutOptions.Colors = _catData.Select(c => c.Color).ToList();
        _catLoading = false;
        StateHasChanged();
    }

    private async Task SetFlowPeriodAsync(string period)
    {
        if (_flowPeriod == period)
            return;
        _flowPeriod = period;
        await LoadFlowAsync();
    }

    // Loads income/expense/net for the selected period and rebuilds the bar chart's points.
    private async Task LoadFlowAsync()
    {
        _flowLoading = true;
        StateHasChanged();
        var f = await Api.GetCashFlowAsync(_flowPeriod);
        _flow =
        [
            new FlowPoint("Příjmy", f.Income),
            new FlowPoint("Výdaje", f.Expense),
            new FlowPoint("Bilance", f.Net),
        ];
        _flowLoading = false;
        StateHasChanged();
    }
}
