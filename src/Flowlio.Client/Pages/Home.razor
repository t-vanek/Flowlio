@page "/"
@attribute [Authorize]
@using ApexCharts
@inject FlowlioApi Api
@inject IJSRuntime JS
@inject CurrentUserState CurrentUser

<PageTitle>Přehled – Flowlio</PageTitle>

<h1 class="page-title">Přehled</h1>

@if (!_canView)
{
    <FluentCard Class="panel">
        <FluentMessageBar Intent="MessageIntent.Warning">Nemáte oprávnění zobrazit finance této rodiny.</FluentMessageBar>
    </FluentCard>
}
else if (_summary is null)
{
    <FluentProgressRing />
}
else
{
    <div class="kpi-grid">
        <FluentCard Class="kpi-card">
            <div class="kpi-label">Celkový zůstatek</div>
            <div class="kpi-value">@Formatting.Money(_summary.TotalBalance)</div>
        </FluentCard>
        <FluentCard Class="kpi-card">
            <div class="kpi-label">Příjmy tento měsíc</div>
            <div class="kpi-value income">@Formatting.Money(_summary.IncomeThisMonth)</div>
        </FluentCard>
        <FluentCard Class="kpi-card">
            <div class="kpi-label">Výdaje tento měsíc</div>
            <div class="kpi-value expense">@Formatting.Money(_summary.ExpenseThisMonth)</div>
        </FluentCard>
        <FluentCard Class="kpi-card">
            <div class="kpi-label">Bilance měsíce</div>
            <div class="kpi-value @(_summary.NetThisMonth >= 0 ? "income" : "expense")">@Formatting.Money(_summary.NetThisMonth)</div>
        </FluentCard>
    </div>

    <div class="panel-grid">
        <FluentCard Class="panel">
            <h2 class="panel-title">Největší výdaje (tento měsíc)</h2>
            @if (_summary.TopExpenseCategories.Count == 0)
            {
                <p class="muted">Zatím žádné kategorizované výdaje.</p>
            }
            else
            {
                <ApexChart TItem="CategorySpendDto" Options="_donutOptions" Height="260">
                    <ApexPointSeries TItem="CategorySpendDto"
                                     Items="_summary.TopExpenseCategories"
                                     Name="Výdaje"
                                     SeriesType="SeriesType.Donut"
                                     XValue="@(c => c.CategoryName)"
                                     YValue="@(c => (decimal?)Math.Abs(c.Amount))" />
                </ApexChart>
                <div class="chart-legend">
                    @foreach (var c in _summary.TopExpenseCategories)
                    {
                        <div class="bar-row">
                            <span class="bar-dot" style="background:@c.Color"></span>
                            <span class="bar-name">@c.CategoryName</span>
                            <span class="bar-amount">@Formatting.Money(c.Amount)</span>
                        </div>
                    }
                </div>
            }
        </FluentCard>

        <FluentCard Class="panel">
            <h2 class="panel-title">Příjmy vs. výdaje (tento měsíc)</h2>
            <ApexChart TItem="FlowPoint" Options="_barOptions" Height="260">
                <ApexPointSeries TItem="FlowPoint"
                                 Items="_flow"
                                 Name="Částka"
                                 SeriesType="SeriesType.Bar"
                                 XValue="@(p => p.Label)"
                                 YValue="@(p => (decimal?)p.Value)" />
            </ApexChart>
        </FluentCard>

        <FluentCard Class="panel">
            <h2 class="panel-title">Nadcházející platby (30 dní)</h2>
            @if (_summary.Upcoming.Count == 0)
            {
                <p class="muted">Žádné naplánované platby.</p>
            }
            else
            {
                @foreach (var u in _summary.Upcoming)
                {
                    <div class="bar-row">
                        <span class="bar-name">@u.Name</span>
                        <span class="muted">@(u.DueDate?.ToString("d.M.yyyy"))</span>
                        <span class="bar-amount expense">@Formatting.Money(u.Amount)</span>
                    </div>
                }
            }
        </FluentCard>
    </div>
}

@code {
    private DashboardSummaryDto? _summary;
    private bool _canView;
    private ApexChartOptions<CategorySpendDto> _donutOptions = new();
    private ApexChartOptions<FlowPoint> _barOptions = new();
    private List<FlowPoint> _flow = [];

    private sealed record FlowPoint(string Label, decimal Value);

    protected override async Task OnInitializedAsync()
    {
        _canView = await CurrentUser.CanAsync(Permission.ViewFinances);
        if (!_canView)
            return;

        _summary = await Api.GetDashboardAsync();

        var effective = await JS.InvokeAsync<string>("flowlioTheme.effective");
        var mode = effective == "dark" ? Mode.Dark : Mode.Light;

        _donutOptions = new ApexChartOptions<CategorySpendDto>
        {
            Chart = new Chart { Background = "transparent", FontFamily = "inherit" },
            Theme = new Theme { Mode = mode },
            Colors = _summary?.TopExpenseCategories.Select(c => c.Color).ToList(),
            Legend = new Legend { Position = LegendPosition.Bottom },
            DataLabels = new DataLabels { Enabled = false },
        };

        _flow =
        [
            new FlowPoint("Příjmy", Math.Abs(_summary?.IncomeThisMonth ?? 0)),
            new FlowPoint("Výdaje", Math.Abs(_summary?.ExpenseThisMonth ?? 0)),
            new FlowPoint("Bilance", _summary?.NetThisMonth ?? 0),
        ];

        _barOptions = new ApexChartOptions<FlowPoint>
        {
            Chart = new Chart { Background = "transparent", FontFamily = "inherit", Toolbar = new Toolbar { Show = false } },
            Theme = new Theme { Mode = mode },
            Colors = ["#16a34a", "#dc2626", "#2563eb"],
            PlotOptions = new PlotOptions { Bar = new PlotOptionsBar { Distributed = true, BorderRadius = 6, ColumnWidth = "45%" } },
            Legend = new Legend { Show = false },
            DataLabels = new DataLabels { Enabled = false },
        };
    }
}
